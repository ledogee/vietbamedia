---
---

<canvas id="interactive-bg" aria-hidden="true"></canvas>

<style>
  #interactive-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("interactive-bg") as HTMLCanvasElement;
  if (canvas) {
   try {
    // ── Config ──
    const countX = 100;
    const countY = 55;
    const count = countX * countY;

    // ── Renderer ──
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: false,
      powerPreference: "high-performance",
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setClearColor(0x000000, 0);

    // ── Scene + Camera ──
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      75,
      window.innerWidth / window.innerHeight,
      0.1,
      100
    );
    camera.position.z = 5;

    // ── Uniforms ──
    const uniforms = {
      uTime: { value: 0 },
      uMouse: { value: new THREE.Vector2(0, 0) },
      uResolution: {
        value: new THREE.Vector2(window.innerWidth, window.innerHeight),
      },
      uMobile: { value: window.innerWidth <= 768 ? 1.0 : 0.0 },
    };

    // ── Shader Material ──
    const vertexShader = `
      uniform float uTime;
      uniform vec2 uMouse;
      uniform float uMobile;
      varying vec2 vUv;
      varying float vSize;
      varying vec2 vPos;

      attribute vec3 aOffset;
      attribute float aRandom;

      #define PI 3.14159265359

      float hash(vec2 p) {
        return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453);
      }
      float noise(vec2 p) {
        vec2 i = floor(p);
        vec2 f = fract(p);
        f = f * f * (3.0 - 2.0 * f);
        float a = hash(i);
        float b = hash(i + vec2(1.0, 0.0));
        float c = hash(i + vec2(0.0, 1.0));
        float d = hash(i + vec2(1.0, 1.0));
        return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
      }

      mat2 rotate2d(float _angle) {
        return mat2(cos(_angle), sin(_angle),
                    -sin(_angle), cos(_angle));
      }

      void main() {
        vUv = uv;

        // 1. ALIVE FLOW - curl-like continuous drift
        vec3 pos = aOffset;
        float driftSpeed = uTime * 0.15;
        float dx = sin(driftSpeed + pos.y * 0.5) + sin(driftSpeed * 0.5 + pos.y * 2.0);
        float dy = cos(driftSpeed + pos.x * 0.5) + cos(driftSpeed * 0.5 + pos.x * 2.0);
        pos.x += dx * 0.25;
        pos.y += dy * 0.25;

        // 2. JELLYFISH HALO - breathing ring around mouse
        vec2 relToMouse = pos.xy - uMouse;
        float distFromMouse = length(relToMouse);
        float angleToMouse = atan(relToMouse.y, relToMouse.x);

        float shapeFactor = noise(vec2(angleToMouse * 2.0, uTime * 0.1));
        float breathCycle = sin(uTime * 0.8);
        float currentRadius = 2.2 + breathCycle * 0.3 + (shapeFactor * 0.5);

        float dist = distFromMouse;
        float rimWidth = 1.8;
        float rimInfluence = smoothstep(rimWidth, 0.0, abs(dist - currentRadius));

        // 3. WAVE PUSH - gentle ripple
        vec2 pushDir = normalize(relToMouse + vec2(0.0001, 0.0));
        float pushAmt = (breathCycle * 0.5 + 0.5) * 0.5;
        pos.xy += pushDir * pushAmt * rimInfluence;
        pos.z += rimInfluence * 0.3 * sin(uTime);

        // 4. SIZE & SCALE
        float mobileFactor = mix(1.0, 0.5, uMobile);
        float baseSize = (0.012 + (sin(uTime + pos.x) * 0.003)) * mobileFactor;
        float activeSize = 0.028 * mobileFactor;
        float currentScale = baseSize + (rimInfluence * activeSize);
        float stretch = rimInfluence * 0.02;

        vec3 transformed = position;
        transformed.x *= (currentScale + stretch);
        transformed.y *= currentScale * 0.85;

        vSize = rimInfluence;
        vPos = pos.xy;

        // 5. ROTATION - radial alignment toward mouse
        float finalAngle = angleToMouse;
        transformed.xy = rotate2d(finalAngle) * transformed.xy;

        gl_Position = projectionMatrix * modelViewMatrix * vec4(pos + transformed, 1.0);
      }
    `;

    const fragmentShader = `
      uniform float uTime;
      varying vec2 vUv;
      varying float vSize;
      varying vec2 vPos;

      void main() {
        // Pill shape with rounded corners
        vec2 center = vec2(0.5);
        vec2 pos = abs(vUv - center) * 2.0;
        float d = pow(pow(pos.x, 2.6) + pow(pos.y, 2.6), 1.0 / 2.6);
        float alpha = 1.0 - smoothstep(0.8, 1.0, d);
        if (alpha < 0.01) discard;

        // Vietba brand colors
        vec3 navy   = vec3(0.04, 0.15, 0.25);   // #0A2540 - idle base
        vec3 cOrange = vec3(0.91, 0.35, 0.13);   // #E85A20 - primary
        vec3 cPurple = vec3(0.39, 0.36, 1.0);    // #635BFF - blurple
        vec3 cCyan   = vec3(0.0, 0.83, 1.0);     // #00D4FF - accent
        vec3 cPink   = vec3(0.88, 0.13, 0.31);   // #E02050 - accent

        // Dynamic color shifting across the field
        float t = uTime * 1.2;
        float p1 = sin(vPos.x * 0.8 + t);
        float p2 = sin(vPos.y * 0.8 + t * 0.8 + p1);
        float p3 = cos(vPos.x * 0.5 - t * 0.6 + p2 * 0.5);

        // Four-way color blend for rich variation
        vec3 activeColor = mix(cOrange, cPurple, p1 * 0.5 + 0.5);
        activeColor = mix(activeColor, cCyan, p2 * 0.5 + 0.5);
        activeColor = mix(activeColor, cPink, p3 * 0.3 + 0.35);

        // Idle → active transition
        vec3 finalColor = mix(navy, activeColor, smoothstep(0.1, 0.8, vSize));
        float finalAlpha = alpha * mix(0.4, 0.95, vSize);

        gl_FragColor = vec4(finalColor, finalAlpha);
      }
    `;

    const material = new THREE.ShaderMaterial({
      uniforms,
      vertexShader,
      fragmentShader,
      transparent: true,
      depthWrite: false,
    });

    // ── Geometry + Instanced Mesh ──
    const geometry = new THREE.PlaneGeometry(1, 1);

    const offsets = new Float32Array(count * 3);
    const randoms = new Float32Array(count);
    const angles = new Float32Array(count);

    const gridWidth = 34;
    const gridHeight = 22;
    const jitter = 0.25;

    let idx = 0;
    for (let y = 0; y < countY; y++) {
      for (let x = 0; x < countX; x++) {
        const u = x / (countX - 1);
        const v = y / (countY - 1);
        let px = (u - 0.5) * gridWidth;
        let py = (v - 0.5) * gridHeight;
        px += (Math.random() - 0.5) * jitter;
        py += (Math.random() - 0.5) * jitter;

        offsets[idx * 3] = px;
        offsets[idx * 3 + 1] = py;
        offsets[idx * 3 + 2] = 0;
        randoms[idx] = Math.random();
        angles[idx] = Math.random() * Math.PI * 2;
        idx++;
      }
    }

    geometry.setAttribute(
      "aOffset",
      new THREE.InstancedBufferAttribute(offsets, 3)
    );
    geometry.setAttribute(
      "aRandom",
      new THREE.InstancedBufferAttribute(randoms, 1)
    );
    geometry.setAttribute(
      "aAngleOffset",
      new THREE.InstancedBufferAttribute(angles, 1)
    );

    const mesh = new THREE.InstancedMesh(geometry, material, count);
    scene.add(mesh);

    // ── Mouse tracking ──
    let hovering = true;
    const targetMouse = new THREE.Vector2(0, 0);
    const currentMouse = new THREE.Vector2(0, 0);
    const dragFactor = 0.055;

    function getViewportCoords(clientX: number, clientY: number) {
      // Convert screen coords to Three.js world space (at z=0 plane)
      const ndcX = (clientX / window.innerWidth) * 2 - 1;
      const ndcY = -(clientY / window.innerHeight) * 2 + 1;

      // Approximate viewport dimensions at z=5
      const vFov = (camera.fov * Math.PI) / 180;
      const height = 2 * Math.tan(vFov / 2) * camera.position.z;
      const width = height * camera.aspect;

      return new THREE.Vector2(
        (ndcX * width) / 2,
        (ndcY * height) / 2
      );
    }

    document.addEventListener("mousemove", (e) => {
      const coords = getViewportCoords(e.clientX, e.clientY);
      targetMouse.set(coords.x, coords.y);
      hovering = true;
    });
    document.body.addEventListener("mouseleave", () => {
      hovering = false;
    });
    document.body.addEventListener("mouseenter", () => {
      hovering = true;
    });

    // Touch support
    document.addEventListener(
      "touchmove",
      (e) => {
        if (e.touches.length) {
          const coords = getViewportCoords(
            e.touches[0].clientX,
            e.touches[0].clientY
          );
          targetMouse.set(coords.x, coords.y);
          hovering = true;
        }
      },
      { passive: true }
    );
    document.addEventListener("touchend", () => {
      hovering = false;
    });

    // ── Animation loop ──
    const clock = new THREE.Clock();

    function animate() {
      requestAnimationFrame(animate);

      const elapsed = clock.getElapsedTime();
      uniforms.uTime.value = elapsed;

      // Idle drift: Lissajous wander so the halo roams on its own
      const driftAmp = 3.0;
      const idleDriftX =
        Math.sin(elapsed * 0.22) * driftAmp +
        Math.sin(elapsed * 0.47 + 2) * driftAmp * 0.6 +
        Math.cos(elapsed * 0.13 + 5) * driftAmp * 0.3;
      const idleDriftY =
        Math.cos(elapsed * 0.18 + 1) * driftAmp +
        Math.cos(elapsed * 0.38 + 4) * driftAmp * 0.5 +
        Math.sin(elapsed * 0.11 + 3) * driftAmp * 0.35;

      // Smooth mouse follow with heavy drag + idle drift
      let tx = idleDriftX,
        ty = idleDriftY;
      if (hovering) {
        tx = targetMouse.x + idleDriftX * 0.3;
        ty = targetMouse.y + idleDriftY * 0.3;
      }
      currentMouse.x += (tx - currentMouse.x) * dragFactor;
      currentMouse.y += (ty - currentMouse.y) * dragFactor;
      uniforms.uMouse.value.set(currentMouse.x, currentMouse.y);

      renderer.render(scene, camera);
    }

    animate();

    // ── Resize ──
    let resizeTimeout: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const w = window.innerWidth;
        const h = window.innerHeight;
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
        renderer.setSize(w, h);
        uniforms.uResolution.value.set(w, h);
        uniforms.uMobile.value = w <= 768 ? 1.0 : 0.0;
      }, 150);
    });
   } catch (e) {
    console.warn("Interactive background disabled:", (e as Error).message);
    canvas.style.display = "none";
   }
  }
</script>
