---
/**
 * InteractiveBackground.astro
 * A full-page interactive canvas background with small dashes/particles
 * that rotate to follow the mouse cursor — inspired by the Antigravity homepage.
 * Uses the site's navy + cream + gold palette.
 */
---

<canvas id="interactive-bg" aria-hidden="true"></canvas>

<style>
  #interactive-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const canvas = document.getElementById('interactive-bg') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  /* ── Palette ───────────────────────────────────────────── */
  const COLORS = [
    { r: 212, g: 165, b: 116 },  // gold  #d4a574
    { r: 238, g: 224, b: 203 },  // cream #eee0cb
    { r: 186, g: 168, b: 152 },  // taupe #baa898
    { r: 100, g: 120, b: 180 },  // muted-blue accent
    { r: 160, g: 145, b: 130 },  // warm-grey
  ];

  /* ── Config ────────────────────────────────────────────── */
  const SPACING = 32;           // px between dashes
  const DASH_LEN = 10;          // dash half-length
  const DASH_WIDTH = 1.8;
  const INFLUENCE_RADIUS = 180; // px — mouse influence zone
  const BASE_OPACITY = 0.12;    // resting opacity
  const ACTIVE_OPACITY = 0.55;  // opacity near cursor
  const LERP_SPEED = 0.08;      // rotation smoothing

  /* ── State ─────────────────────────────────────────────── */
  interface Dash {
    x: number;
    y: number;
    angle: number;          // current visual angle
    targetAngle: number;    // angle toward mouse
    baseAngle: number;      // rest angle
    color: { r: number; g: number; b: number };
    opacity: number;
  }

  let dashes: Dash[] = [];
  let mouse = { x: -9999, y: -9999 };
  let animId = 0;
  let cols = 0;
  let rows = 0;

  /* ── Build grid ────────────────────────────────────────── */
  function buildGrid() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    cols = Math.ceil(canvas.width / SPACING) + 1;
    rows = Math.ceil(canvas.height / SPACING) + 1;
    dashes = [];

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const baseAngle = Math.random() * Math.PI * 2;
        dashes.push({
          x: c * SPACING,
          y: r * SPACING,
          angle: baseAngle,
          targetAngle: baseAngle,
          baseAngle,
          color: COLORS[Math.floor(Math.random() * COLORS.length)],
          opacity: BASE_OPACITY,
        });
      }
    }
  }

  /* ── Lerp angle (shortest arc) ─────────────────────────── */
  function lerpAngle(a: number, b: number, t: number): number {
    let diff = b - a;
    while (diff > Math.PI) diff -= Math.PI * 2;
    while (diff < -Math.PI) diff += Math.PI * 2;
    return a + diff * t;
  }

  /* ── Render loop ───────────────────────────────────────── */
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (const d of dashes) {
      const dx = mouse.x - d.x;
      const dy = mouse.y - d.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < INFLUENCE_RADIUS) {
        const t = 1 - dist / INFLUENCE_RADIUS;        // 0 → 1  (nearer = stronger)
        d.targetAngle = Math.atan2(dy, dx);
        d.opacity = BASE_OPACITY + (ACTIVE_OPACITY - BASE_OPACITY) * t;
      } else {
        d.targetAngle = d.baseAngle;
        d.opacity += (BASE_OPACITY - d.opacity) * 0.04;
      }

      d.angle = lerpAngle(d.angle, d.targetAngle, LERP_SPEED);

      const { r, g, b } = d.color;
      ctx.strokeStyle = `rgba(${r},${g},${b},${d.opacity})`;
      ctx.lineWidth = DASH_WIDTH;
      ctx.lineCap = 'round';
      ctx.beginPath();
      ctx.moveTo(
        d.x - Math.cos(d.angle) * DASH_LEN,
        d.y - Math.sin(d.angle) * DASH_LEN,
      );
      ctx.lineTo(
        d.x + Math.cos(d.angle) * DASH_LEN,
        d.y + Math.sin(d.angle) * DASH_LEN,
      );
      ctx.stroke();
    }

    animId = requestAnimationFrame(draw);
  }

  /* ── Events ────────────────────────────────────────────── */
  window.addEventListener('mousemove', (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  window.addEventListener('mouseleave', () => {
    mouse.x = -9999;
    mouse.y = -9999;
  });

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      cancelAnimationFrame(animId);
      buildGrid();
      draw();
    }, 150);
  });

  /* ── Kick off ──────────────────────────────────────────── */
  buildGrid();
  draw();
</script>
