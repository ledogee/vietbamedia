---
---

<canvas id="interactive-bg" aria-hidden="true"></canvas>

<style>
  #interactive-bg {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const canvas = document.getElementById("interactive-bg") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  const COLORS = [
    [255, 107, 53],
    [99, 91, 255],
    [0, 212, 255],
    [255, 56, 100],
    [255, 159, 67],
  ];

  const mob = window.innerWidth <= 768;
  const N = mob ? 120 : 250;
  const R_IN = 0;
  const R_OUT = mob ? 280 : 500;
  const RX = mob ? 1 : 1.5;
  const RY = mob ? 5 : 8;
  const FOLLOW = 0.17;
  const BREATHE = 0.25;

  interface P {
    x: number;
    y: number;
    oa: number;
    or: number;
    os: number;
    c: number[];
    op: number;
    ly: number;
    pp: number;
    dx: number;
    dy: number; // displacement (water push)
  }

  let ps: P[] = [];
  let mx = -9999,
    my = -9999,
    sx = -9999,
    sy = -9999;
  let active = false,
    t = 0;
  // Mouse velocity tracking
  let prevMx = -9999,
    prevMy = -9999;
  let vx = 0,
    vy = 0;

  function init() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    ps = [];
    for (let i = 0; i < N; i++) {
      const ly = Math.random();
      const r = Math.random();
      // sqrt distribution: uniform area fill across the disc (no banding)
      const orbitR = R_IN + (R_OUT - R_IN) * Math.sqrt(r) + 30;
      ps.push({
        x: -9999,
        y: -9999,
        oa: i * 2.399 + ly * 0.3, // golden angle
        or: orbitR,
        os: (0.12 + r * 0.06) * (r < 0.5 ? 1 : -1) * (0.5 + ly * 0.5),
        c: COLORS[i % 5],
        op: 0,
        ly,
        pp: Math.random() * 6.283,
        dx: 0,
        dy: 0,
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    t += 0.016;

    if (mx > -999) {
      if (sx < -999) {
        sx = mx;
        sy = my;
      } else {
        sx += (mx - sx) * 0.26;
        sy += (my - sy) * 0.26;
      }
      active = true;
    } else active = false;

    // Track mouse velocity
    if (mx > -999 && prevMx > -999) {
      vx += (mx - prevMx - vx) * 0.3;
      vy += (my - prevMy - vy) * 0.3;
    } else {
      vx *= 0.9;
      vy *= 0.9;
    }
    prevMx = mx;
    prevMy = my;
    const speed = Math.sqrt(vx * vx + vy * vy);

    // Idle drift: center wanders when mouse is still
    const driftAmount = Math.max(0, 1 - speed / 2) * 120;
    const driftX = Math.sin(t * 0.4) * driftAmount + Math.sin(t * 0.7 + 2) * driftAmount * 0.5;
    const driftY = Math.cos(t * 0.3 + 1) * driftAmount + Math.cos(t * 0.6 + 4) * driftAmount * 0.4;
    sx += driftX * 0.04;
    sy += driftY * 0.04;

    const breathe = 1 + Math.sin(t * 1.2) * BREATHE;
    const mid = (R_IN + R_OUT) * 0.5 * breathe;
    const hw = (R_OUT - R_IN) * 0.5 * breathe;
    // Runtime angular repulsion: prevent overlap
    const REP_ARC = 12; // min pixel gap
    for (let i = 0; i < ps.length; i++) {
      const p = ps[i];
      const minA = REP_ARC / Math.max(p.or * breathe, 1);
      for (let j = i + 1; j < ps.length; j++) {
        const q = ps[j];
        if (Math.abs(q.or - p.or) > 25) continue; // different band
        let diff = q.oa - p.oa;
        while (diff > Math.PI) diff -= 6.283;
        while (diff < -Math.PI) diff += 6.283;
        if (Math.abs(diff) < minA) {
          const push = (minA - Math.abs(diff)) * 0.3;
          const sign = diff >= 0 ? 1 : -1;
          q.oa += sign * push;
          p.oa -= sign * push;
        }
      }
    }

    for (const p of ps) {
      // Asymmetric breathing: slow drift out, fast snap in
      const rawPhase = (t * 1.47 + p.pp * 3) % 6.283;
      // Skewed wave: positive (out) is longer, negative (in) is shorter
      const skew = Math.sin(rawPhase) > 0
        ? Math.pow(Math.sin(rawPhase), 0.5)
        : -Math.pow(-Math.sin(rawPhase), 2.0);
      const waveSpeed = 0.4 + skew * 0.3;
      const wiggle = Math.sin(t * 1.25 * waveSpeed + p.pp) * 0.03;
      const radialBreath = skew * 40;
      const angle = p.oa + wiggle;
      const r = p.or * breathe + radialBreath;
      const baseX = sx + Math.cos(angle) * r;
      const baseY = sy + Math.sin(angle) * r;

      // Water wake: push particles based on mouse velocity & proximity
      if (active && speed > 1) {
        const pdx = baseX - sx,
          pdy = baseY - sy;
        const pDist = Math.sqrt(pdx * pdx + pdy * pdy);
        // Particles closer to center get pushed more
        const influence =
          Math.max(0, 1 - pDist / (R_OUT * breathe)) * Math.min(speed / 8, 1);
        // Push opposite to velocity (wake trails behind)
        p.dx += -vx * influence * 0.15;
        p.dy += -vy * influence * 0.15;
      }
      // Spring back + damping
      p.dx *= 0.92;
      p.dy *= 0.92;

      const tx = baseX + p.dx;
      const ty = baseY + p.dy;

      if (active) {
        const f = FOLLOW * (0.5 + p.ly * 0.8);
        if (p.x < -999) {
          p.x = tx;
          p.y = ty;
        } else {
          p.x += (tx - p.x) * f;
          p.y += (ty - p.y) * f;
        }
        p.op += (0.55 * (0.4 + p.ly * 0.6) - p.op) * 0.05;
      } else {
        p.op *= 0.97;
        if (p.op < 0.004) {
          p.x = -9999;
          continue;
        }
      }
      if (p.op < 0.004) continue;

      // Bell curve size: Gaussian peak at donut midpoint, tapers at edges
      const d = Math.sqrt((p.x - sx) ** 2 + (p.y - sy) ** 2);
      const norm = (d - mid) / (hw * 0.6); // normalize distance from mid
      const s = 0.3 + 0.7 * Math.exp(-norm * norm * 0.5); // Gaussian: 1.0 at center, 0.3 at edges
      // Proximity shrink: within 100px of mouse → tiny dot
      const proxScale = Math.min(1, Math.max(0.3, d / 100));
      const pulse = 1 - Math.abs(Math.sin(t * 1.2 + p.pp)) * 0.6;
      const sr = RX * proxScale * s;
      const lr = Math.max(RY * (0.7 + p.ly * 0.5) * s * pulse * proxScale, sr);
      const a = Math.atan2(sy - p.y, sx - p.x);

      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(a);
      ctx.beginPath();
      ctx.ellipse(0, 0, lr, sr, 0, 0, 6.283);
      ctx.fillStyle = `rgba(${p.c[0]},${p.c[1]},${p.c[2]},${p.op})`;
      ctx.fill();
      ctx.restore();
    }
    requestAnimationFrame(draw);
  }

  window.addEventListener("mousemove", (e) => {
    mx = e.clientX;
    my = e.clientY;
  });
  window.addEventListener("mouseleave", () => {
    mx = my = sx = sy = -9999;
  });
  window.addEventListener(
    "touchmove",
    (e) => {
      if (e.touches.length) {
        mx = e.touches[0].clientX;
        my = e.touches[0].clientY;
      }
    },
    { passive: true }
  );
  window.addEventListener("touchend", () => {
    mx = my = sx = sy = -9999;
  });

  let rt: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(rt);
    rt = setTimeout(() => {
      init();
    }, 150);
  });

  init();
  draw();
</script>
