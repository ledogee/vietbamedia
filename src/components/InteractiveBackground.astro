---
/**
 * InteractiveBackground.astro
 * A full-page interactive canvas background with small dashes/particles
 * that rotate to follow the mouse cursor — inspired by the Antigravity homepage.
 * Uses Stripe-inspired navy + orange/pink/purple palette.
 */
---

<canvas id="interactive-bg" aria-hidden="true"></canvas>

<style>
  #interactive-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const canvas = document.getElementById('interactive-bg') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  /* ── Palette — Stripe-inspired with media orange ── */
  const COLORS = [
    { r: 255, g: 107, b: 53  },  // orange  #FF6B35
    { r: 99,  g: 91,  b: 255 },  // blurple #635BFF
    { r: 0,   g: 212, b: 255 },  // cyan    #00D4FF
    { r: 255, g: 56,  b: 100 },  // pink    #FF3864
    { r: 173, g: 189, b: 204 },  // muted-silver
  ];

  /* ── Config (responsive) ── */
  const isMobile = window.innerWidth <= 768;
  const isSmall = window.innerWidth <= 480;
  const SPACING = isSmall ? 52 : isMobile ? 44 : 32;
  const DASH_LEN = isSmall ? 7 : isMobile ? 8 : 10;
  const DASH_WIDTH = isMobile ? 1.4 : 1.8;
  const INFLUENCE_RADIUS = isSmall ? 100 : isMobile ? 130 : 180;
  const BASE_OPACITY = 0.08;
  const ACTIVE_OPACITY = isMobile ? 0.40 : 0.50;
  const LERP_SPEED = 0.08;

  /* ── State ── */
  interface Dash {
    x: number;
    y: number;
    angle: number;
    targetAngle: number;
    baseAngle: number;
    color: { r: number; g: number; b: number };
    opacity: number;
  }

  let dashes: Dash[] = [];
  let mouse = { x: -9999, y: -9999 };
  let animId = 0;
  let cols = 0;
  let rows = 0;

  /* ── Build grid ── */
  function buildGrid() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    cols = Math.ceil(canvas.width / SPACING) + 1;
    rows = Math.ceil(canvas.height / SPACING) + 1;
    dashes = [];

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const baseAngle = Math.random() * Math.PI * 2;
        dashes.push({
          x: c * SPACING,
          y: r * SPACING,
          angle: baseAngle,
          targetAngle: baseAngle,
          baseAngle,
          color: COLORS[Math.floor(Math.random() * COLORS.length)],
          opacity: BASE_OPACITY,
        });
      }
    }
  }

  /* ── Lerp angle (shortest arc) ── */
  function lerpAngle(a: number, b: number, t: number): number {
    let diff = b - a;
    while (diff > Math.PI) diff -= Math.PI * 2;
    while (diff < -Math.PI) diff += Math.PI * 2;
    return a + diff * t;
  }

  /* ── Render loop ── */
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (const d of dashes) {
      const dx = mouse.x - d.x;
      const dy = mouse.y - d.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < INFLUENCE_RADIUS) {
        const t = 1 - dist / INFLUENCE_RADIUS;
        d.targetAngle = Math.atan2(dy, dx);
        d.opacity = BASE_OPACITY + (ACTIVE_OPACITY - BASE_OPACITY) * t;
      } else {
        d.targetAngle = d.baseAngle;
        d.opacity += (BASE_OPACITY - d.opacity) * 0.04;
      }

      d.angle = lerpAngle(d.angle, d.targetAngle, LERP_SPEED);

      const { r, g, b } = d.color;
      ctx.strokeStyle = `rgba(${r},${g},${b},${d.opacity})`;
      ctx.lineWidth = DASH_WIDTH;
      ctx.lineCap = 'round';
      ctx.beginPath();
      ctx.moveTo(
        d.x - Math.cos(d.angle) * DASH_LEN,
        d.y - Math.sin(d.angle) * DASH_LEN,
      );
      ctx.lineTo(
        d.x + Math.cos(d.angle) * DASH_LEN,
        d.y + Math.sin(d.angle) * DASH_LEN,
      );
      ctx.stroke();
    }

    animId = requestAnimationFrame(draw);
  }

  /* ── Events ── */
  window.addEventListener('mousemove', (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  window.addEventListener('mouseleave', () => {
    mouse.x = -9999;
    mouse.y = -9999;
  });

  // Touch support for mobile
  window.addEventListener('touchmove', (e) => {
    if (e.touches.length > 0) {
      mouse.x = e.touches[0].clientX;
      mouse.y = e.touches[0].clientY;
    }
  }, { passive: true });

  window.addEventListener('touchend', () => {
    mouse.x = -9999;
    mouse.y = -9999;
  });

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      cancelAnimationFrame(animId);
      buildGrid();
      draw();
    }, 150);
  });

  /* ── Kick off ── */
  buildGrid();
  draw();
</script>
