---
/**
 * HeroSlideshow.astro
 * Fullscreen auto-playing image slideshow for the homepage hero section.
 * DatVietVAC-inspired with fade transitions + dot indicators.
 */
interface Props {
  slides: { img: string; title?: string; subtitle?: string }[];
  interval?: number;
  base: string;
}
const { slides, interval = 5000, base } = Astro.props;
---

<section class="hero-slideshow" id="hero-slideshow" data-interval={interval}>
  <div class="slideshow-track">
    {slides.map((slide, i) => (
      <div class={`slideshow-slide ${i === 0 ? 'active' : ''}`} data-index={i}>
        <img src={`${base}${slide.img}`} alt={slide.title || `Slide ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
        {(slide.title || slide.subtitle) && (
          <div class="slide-caption">
            {slide.title && <h2>{slide.title}</h2>}
            {slide.subtitle && <p>{slide.subtitle}</p>}
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Gradient overlay at bottom for smooth transition to content -->
  <div class="slideshow-overlay" aria-hidden="true"></div>

  <!-- Dot indicators -->
  <div class="slideshow-dots" aria-label="Slide navigation">
    {slides.map((_, i) => (
      <button
        class={`dot ${i === 0 ? 'active' : ''}`}
        data-slide={i}
        aria-label={`Go to slide ${i + 1}`}
      />
    ))}
  </div>

  <!-- Scroll indicator -->
  <div class="slideshow-scroll-hint" aria-hidden="true">
    <div class="scroll-arrow"></div>
  </div>
</section>

<script>
  const slideshow = document.getElementById('hero-slideshow');
  if (slideshow) {
    const slides = slideshow.querySelectorAll<HTMLDivElement>('.slideshow-slide');
    const dots = slideshow.querySelectorAll<HTMLButtonElement>('.dot');
    const intervalMs = parseInt(slideshow.dataset.interval || '5000');
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = index;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    function next() {
      goTo((current + 1) % slides.length);
    }

    function startAutoPlay() {
      timer = setInterval(next, intervalMs);
    }

    function resetAutoPlay() {
      clearInterval(timer);
      startAutoPlay();
    }

    // Dot click handlers
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        goTo(i);
        resetAutoPlay();
      });
    });

    // Pause on hover (desktop)
    slideshow.addEventListener('mouseenter', () => clearInterval(timer));
    slideshow.addEventListener('mouseleave', startAutoPlay);

    // Touch swipe support
    let touchStartX = 0;
    slideshow.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    slideshow.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          goTo((current + 1) % slides.length);
        } else {
          goTo((current - 1 + slides.length) % slides.length);
        }
        resetAutoPlay();
      }
    }, { passive: true });

    startAutoPlay();
  }
</script>

<style>
.hero-slideshow {
  position: relative;
  width: 100%;
  height: 100vh;
  height: 100dvh;
  overflow: hidden;
  background: #000;
}

.slideshow-track {
  position: relative;
  width: 100%;
  height: 100%;
}

.slideshow-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 1.2s ease-in-out;
  z-index: 0;
}
.slideshow-slide.active {
  opacity: 1;
  z-index: 1;
}
.slideshow-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* Caption overlay */
.slide-caption {
  position: absolute;
  bottom: 120px;
  left: 0;
  right: 0;
  z-index: 3;
  text-align: center;
  padding: 0 24px;
}
.slide-caption h2 {
  font-size: clamp(1.6rem, 4vw, 3rem);
  font-weight: 800;
  color: #fff;
  text-shadow: 0 2px 20px rgba(0,0,0,0.6);
  margin-bottom: 8px;
}
.slide-caption p {
  font-size: clamp(0.9rem, 1.5vw, 1.15rem);
  color: rgba(255,255,255,0.85);
  text-shadow: 0 1px 10px rgba(0,0,0,0.5);
  max-width: 600px;
  margin: 0 auto;
}

/* Bottom gradient overlay */
.slideshow-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 250px;
  background: linear-gradient(to top, #FFFFFF 0%, transparent 100%);
  z-index: 2;
  pointer-events: none;
}

/* Dot indicators */
.slideshow-dots {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  z-index: 5;
}
.dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: rgba(255,255,255,0.35);
  border: 2px solid rgba(255,255,255,0.5);
  cursor: pointer;
  transition: all 0.3s ease;
  padding: 0;
}
.dot.active {
  background: var(--color-accent-orange, #FF6B35);
  border-color: var(--color-accent-orange, #FF6B35);
  box-shadow: 0 0 12px rgba(255, 107, 53, 0.6);
  transform: scale(1.2);
}
.dot:hover:not(.active) {
  background: rgba(255,255,255,0.6);
  transform: scale(1.1);
}

/* Scroll hint */
.slideshow-scroll-hint {
  position: absolute;
  bottom: 70px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 5;
}
.scroll-arrow {
  width: 24px;
  height: 24px;
  border-right: 2px solid rgba(255,255,255,0.5);
  border-bottom: 2px solid rgba(255,255,255,0.5);
  transform: rotate(45deg);
  animation: scrollArrowBounce 2s infinite;
}
@keyframes scrollArrowBounce {
  0%, 100% { transform: rotate(45deg) translateY(0); opacity: 0.5; }
  50% { transform: rotate(45deg) translateY(8px); opacity: 1; }
}

/* Responsive */
@media (max-width: 768px) {
  .hero-slideshow {
    height: 70vh;
    height: 70dvh;
  }
  .slide-caption {
    bottom: 100px;
  }
  .slide-caption h2 {
    font-size: clamp(1.3rem, 5vw, 2rem);
  }
  .slideshow-overlay {
    height: 180px;
  }
  .slideshow-dots {
    bottom: 24px;
  }
  .slideshow-scroll-hint {
    bottom: 56px;
  }
}

@media (max-width: 480px) {
  .hero-slideshow {
    height: 60vh;
    height: 60dvh;
  }
  .slide-caption {
    bottom: 80px;
  }
  .dot {
    width: 10px;
    height: 10px;
  }
  .slideshow-overlay {
    height: 140px;
  }
}
</style>
