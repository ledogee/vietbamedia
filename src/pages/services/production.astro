---
import Layout from '../../layouts/Layout.astro';
import ServiceDetail from '../../components/ServiceDetail.astro';
import vi from '../../i18n/vi.json';
const s = vi.serviceDetail.production;
const t = vi;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout lang="vi">
  <ServiceDetail
    lang="vi"
    sectionTag={s.sectionTag}
    title={s.title}
    subtitle={s.subtitle}
    intro={s.intro}
    achievements={s.achievements}
    highlights={s.highlights}
    gallery={s.gallery}
    ctaTitle={t.home.contactCta}
    ctaSub={t.home.contactCtaSub}
    ctaBtn={t.home.contactCtaBtn}
    ctaLink={`${base}/contact`}
  />
</Layout>
