---
import Layout from '../../layouts/Layout.astro';
import en from '../../i18n/en.json';
const t = en;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const catColors: Record<string, string> = {
  gameshow: '#FF6B35', sitcom: '#FF3864', digital: '#635BFF',
  tv: '#00D4FF', event: '#FF9F43', weather: '#4ecdc4', comms: '#FF6B35'
};
const items = t.projects.items;
const featured = items.slice(0, 3);
const rest = items.slice(3);
---

<Layout lang="en">
  <section class="page-hero prj-hero">
    <div class="container">
      <p class="section-tag fade-in">{t.pageHero.projects.tag}</p>
      <h1 class="section-title fade-in">{t.pageHero.projects.title}</h1>
      <p class="fade-in prj-hero-sub">{t.pageHero.projects.subtitle}</p>
    </div>
  </section>

  <section class="section section-light prj-section">
    <div class="container">
      <!-- Premium Filter Bar -->
      <div class="prj-filter-bar fade-in">
        <button class="prj-filter active" data-cat="all">
          <span class="prj-filter-dot"></span>
          {t.projects.filterAll}
        </button>
        {Object.entries(t.projects.filters).map(([key, label]) => (
          <button class="prj-filter" data-cat={key} style={`--cat:${catColors[key]}`}>
            <span class="prj-filter-dot" style={`background:${catColors[key]}`}></span>
            {label}
          </button>
        ))}
      </div>

      <!-- Hero Featured Row (Apple-style) -->
      <div class="prj-featured fade-in">
        <div class="prj-hero-card" data-cat={featured[0].cat} style={`--cat-color:${catColors[featured[0].cat]}`}>
          <img src={`${base}${featured[0].img}`} alt={featured[0].name} loading="eager" />
          <div class="prj-hero-overlay"></div>
          <div class="prj-hero-content">
            <span class="prj-cat-pill" style={`--pill-color:${catColors[featured[0].cat]}`}>
              {t.projects.filters[featured[0].cat as keyof typeof t.projects.filters]}
            </span>
            <h2>{featured[0].name}</h2>
            <span class="prj-hero-arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"></path></svg>
            </span>
          </div>
        </div>
        <div class="prj-hero-side">
          {featured.slice(1, 3).map((p) => (
            <div class="prj-side-card" data-cat={p.cat} style={`--cat-color:${catColors[p.cat]}`}>
              <img src={`${base}${p.img}`} alt={p.name} loading="eager" />
              <div class="prj-side-overlay"></div>
              <div class="prj-side-content">
                <span class="prj-cat-pill" style={`--pill-color:${catColors[p.cat]}`}>
                  {t.projects.filters[p.cat as keyof typeof t.projects.filters]}
                </span>
                <h3>{p.name}</h3>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Bento Grid (Dribbble / Behance inspired) -->
      <div class="prj-bento">
        {rest.map((p, i) => (
          <div
            class={`prj-bento-card fade-in ${i === 0 || i === 5 || i === 11 || i === 17 ? 'prj-wide' : ''} ${i === 2 || i === 8 || i === 14 ? 'prj-tall' : ''}`}
            data-cat={p.cat}
            style={`--cat-color:${catColors[p.cat]};--i:${i}`}
          >
            <div class="prj-bento-img">
              {p.img && <img src={`${base}${p.img}`} alt={p.name} loading="lazy" />}
              <div class="prj-bento-gradient"></div>
            </div>
            <div class="prj-bento-info">
              <span class="prj-cat-pill" style={`--pill-color:${catColors[p.cat]}`}>
                {t.projects.filters[p.cat as keyof typeof t.projects.filters] || p.cat}
              </span>
              <h4>{p.name}</h4>
              <span class="prj-card-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"></path></svg>
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section-light contact-cta" id="projects-cta">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>{t.home.contactCta}</h2>
        <p>{t.home.contactCtaSub}</p>
        <a href={`${base}/en/contact`} class="btn-glow">{t.home.contactCtaBtn}</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.prj-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.prj-filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = (btn as HTMLElement).dataset.cat;

      // ── Phase 1: Fade out non-matching cards ──
      const allCards = document.querySelectorAll('.prj-hero-card, .prj-side-card, .prj-bento-card');
      allCards.forEach(card => {
        const el = card as HTMLElement;
        const matches = cat === 'all' || el.dataset.cat === cat;
        if (!matches) {
          el.classList.add('prj-hiding');
          el.classList.remove('prj-visible');
        }
      });

      // ── Phase 2: After fade-out completes, collapse hidden cards & reveal matching ones ──
      setTimeout(() => {
        let staggerIndex = 0;
        allCards.forEach(card => {
          const el = card as HTMLElement;
          const matches = cat === 'all' || el.dataset.cat === cat;
          if (!matches) {
            el.classList.add('prj-hidden');
            el.classList.remove('prj-hiding');
          } else {
            el.classList.remove('prj-hidden', 'prj-hiding');
            // Stagger the reveal for a cascading effect
            el.style.transitionDelay = `${staggerIndex * 60}ms`;
            staggerIndex++;
            // Trigger reflow then reveal
            requestAnimationFrame(() => {
              el.classList.add('prj-visible');
            });
          }
        });

        // Clear stagger delays after animation
        setTimeout(() => {
          allCards.forEach(card => {
            (card as HTMLElement).style.transitionDelay = '0ms';
          });
        }, staggerIndex * 60 + 450);

        // ── Featured section collapse ──
        const featuredSection = document.querySelector('.prj-featured') as HTMLElement;
        if (featuredSection) {
          const anyFeaturedVisible = Array.from(
            featuredSection.querySelectorAll('.prj-hero-card, .prj-side-card')
          ).some(c => !c.classList.contains('prj-hidden'));
          if (anyFeaturedVisible) {
            featuredSection.classList.remove('prj-section-collapsed');
          } else {
            featuredSection.classList.add('prj-section-collapsed');
          }
        }
      }, 350);
    });
  });

  // Mark all cards visible on load
  document.querySelectorAll('.prj-hero-card, .prj-side-card, .prj-bento-card').forEach(card => {
    card.classList.add('prj-visible');
  });
</script>

<style>
/* ── Hero ── */
.prj-hero { padding-bottom: 40px; }
.prj-hero-sub {
  font-size: 1.1rem; max-width: 600px; margin: 0 auto 12px;
  color: var(--color-text-dark-secondary);
}
.prj-section { padding-top: 0; }

/* ── Filter Bar (Stripe-style pills) ── */
.prj-filter-bar {
  display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;
  margin-bottom: 48px; padding: 8px;
  background: var(--color-bg-light);
  border-radius: 60px;
  border: 1px solid rgba(10,37,64,0.05);
}
.prj-filter {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 10px 22px;
  border: 1px solid transparent; background: transparent;
  color: var(--color-text-dark-secondary); border-radius: 50px; cursor: pointer;
  font-size: 0.84rem; font-weight: 600; transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
  font-family: var(--font-family); position: relative;
}
.prj-filter-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--color-text-dark-secondary);
  opacity: 0.35; transition: all 0.35s ease;
}
.prj-filter:hover {
  background: rgba(255,107,53,0.06); color: var(--color-text-dark);
}
.prj-filter:hover .prj-filter-dot { opacity: 0.7; }
.prj-filter.active {
  background: #fff; color: var(--color-text-dark);
  box-shadow: 0 2px 12px rgba(10,37,64,0.08), 0 0 0 1px rgba(10,37,64,0.05);
}
.prj-filter.active .prj-filter-dot {
  opacity: 1; background: var(--color-accent-orange);
  box-shadow: 0 0 8px var(--color-glow-orange);
}

/* ── Featured Hero Row (Apple-style) ── */
.prj-hero-card {
  position: relative; border-radius: var(--radius-lg); overflow: hidden;
  height: 480px; cursor: pointer;
  transition: all 0.5s cubic-bezier(0.4,0,0.2,1);
}
.prj-hero-card img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.7s cubic-bezier(0.4,0,0.2,1);
}
.prj-hero-card:hover img { transform: scale(1.06); }
.prj-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent 30%, rgba(10,37,64,0.85) 100%);
  transition: opacity 0.4s ease;
}
.prj-hero-content {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 36px; z-index: 2;
}
.prj-hero-content h2 {
  font-size: 1.8rem; font-weight: 800; color: #fff; margin-top: 12px;
}
.prj-hero-arrow {
  position: absolute; top: 36px; right: 36px; color: #fff;
  width: 40px; height: 40px; border-radius: 50%;
  background: rgba(255,255,255,0.15); backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  transition: all 0.35s ease; opacity: 0; transform: translateY(8px);
}
.prj-hero-card:hover .prj-hero-arrow {
  opacity: 1; transform: translateY(0);
}
.prj-hero-card:hover .prj-hero-arrow { background: rgba(255,255,255,0.25); }

/* ── Side Cards ── */
.prj-hero-side { display: flex; flex-direction: column; gap: 16px; }
.prj-side-card {
  position: relative; border-radius: var(--radius-lg); overflow: hidden;
  flex: 1; cursor: pointer; min-height: 0;
  transition: all 0.5s cubic-bezier(0.4,0,0.2,1);
}
.prj-side-card img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);
}
.prj-side-card:hover img { transform: scale(1.06); }
.prj-side-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent 20%, rgba(10,37,64,0.8) 100%);
}
.prj-side-content {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 24px; z-index: 2;
}
.prj-side-content h3 {
  font-size: 1.15rem; font-weight: 700; color: #fff; margin-top: 10px;
}

/* ── Category Pill (shared) ── */
.prj-cat-pill {
  display: inline-flex; align-items: center;
  font-size: 0.7rem; font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase;
  padding: 5px 14px; border-radius: 50px;
  background: rgba(255,255,255,0.15);
  color: #fff; backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.12);
  transition: all 0.35s ease;
}

/* ── Filter Transition States ── */
.prj-hero-card, .prj-side-card, .prj-bento-card {
  transition: opacity 0.35s cubic-bezier(0.4,0,0.2,1),
              transform 0.4s cubic-bezier(0.4,0,0.2,1),
              max-height 0.5s cubic-bezier(0.4,0,0.2,1),
              margin 0.5s cubic-bezier(0.4,0,0.2,1),
              padding 0.5s cubic-bezier(0.4,0,0.2,1);
}
.prj-visible {
  opacity: 1 !important;
  transform: scale(1) translateY(0) !important;
}
.prj-hiding {
  opacity: 0 !important;
  transform: scale(0.92) translateY(8px) !important;
  pointer-events: none;
}
.prj-hidden {
  opacity: 0 !important;
  transform: scale(0.92) !important;
  position: absolute !important;
  width: 0 !important; height: 0 !important;
  overflow: hidden !important;
  margin: 0 !important; padding: 0 !important;
  pointer-events: none;
}
.prj-featured {
  display: grid; grid-template-columns: 2fr 1fr; gap: 16px;
  margin-bottom: 16px;
  transition: max-height 0.6s cubic-bezier(0.4,0,0.2,1),
              opacity 0.4s cubic-bezier(0.4,0,0.2,1),
              margin 0.5s cubic-bezier(0.4,0,0.2,1);
  max-height: 600px; overflow: hidden;
}
.prj-section-collapsed {
  max-height: 0 !important;
  opacity: 0 !important;
  margin-bottom: 0 !important;
}

/* ── Bento Grid (Dribbble/Behance) ── */
.prj-bento {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 260px;
  gap: 16px;
}
.prj-wide { grid-column: span 2; }
.prj-tall { grid-row: span 2; }

.prj-bento-card {
  position: relative; border-radius: var(--radius-md); overflow: hidden;
  cursor: pointer;
  transition: all 0.45s cubic-bezier(0.4,0,0.2,1);
}
.prj-bento-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 60px rgba(10,37,64,0.15);
  z-index: 3;
}
.prj-bento-img {
  width: 100%; height: 100%; position: relative;
}
.prj-bento-img img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);
}
.prj-bento-card:hover .prj-bento-img img { transform: scale(1.08); }
.prj-bento-gradient {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent 40%, rgba(10,37,64,0.75) 100%);
  opacity: 0; transition: opacity 0.4s ease;
}
.prj-bento-card:hover .prj-bento-gradient { opacity: 1; }

/* Info overlay — slides up on hover */
.prj-bento-info {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 20px; z-index: 2;
  transform: translateY(10px);
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
}
.prj-bento-card:hover .prj-bento-info {
  transform: translateY(0); opacity: 1;
}
.prj-bento-info h4 {
  font-size: 1rem; font-weight: 700; color: #fff;
  margin-top: 8px;
}
.prj-card-arrow {
  position: absolute; top: 20px; right: 20px; color: #fff;
  width: 32px; height: 32px; border-radius: 50%;
  background: rgba(255,255,255,0.15); backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transform: translateX(-8px);
  transition: all 0.35s ease 0.1s;
}
.prj-bento-card:hover .prj-card-arrow {
  opacity: 1; transform: translateX(0);
}

/* Static bottom bar for non-hover (always visible) */
.prj-bento-card::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 60px;
  background: linear-gradient(transparent, rgba(10,37,64,0.5));
  pointer-events: none; transition: opacity 0.35s ease;
}
.prj-bento-card:hover::after { opacity: 0; }

/* ── CTA ── */
.cta-card {
  text-align: center; padding: 80px 40px;
  background: var(--color-gradient); border-radius: var(--radius-lg);
  position: relative; overflow: hidden;
}
.cta-card::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.12) 0%, transparent 60%);
  pointer-events: none;
}
.cta-card h2 {
  font-size: clamp(1.6rem, 3.5vw, 2.5rem); font-weight: 800;
  color: #fff; margin-bottom: 16px; position: relative;
}
.cta-card p {
  color: rgba(255,255,255,0.85); font-size: 1.05rem;
  max-width: 550px; margin: 0 auto 32px; position: relative;
}
.cta-card .btn-glow {
  position: relative; background: #fff; color: var(--color-accent-orange);
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .prj-featured { grid-template-columns: 1fr 1fr; }
  .prj-hero-card { height: 380px; }
  .prj-bento { grid-template-columns: repeat(3, 1fr); grid-auto-rows: 220px; }
}

@media (max-width: 768px) {
  .prj-hero { padding-bottom: 24px; }
  .prj-featured { grid-template-columns: 1fr; gap: 12px; }
  .prj-hero-card { height: 280px; }
  .prj-hero-side { flex-direction: row; }
  .prj-side-card { height: 200px; }
  .prj-bento {
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 200px; gap: 12px;
  }
  .prj-wide { grid-column: span 2; }
  .prj-tall { grid-row: span 1; }
  .prj-hero-content h2 { font-size: 1.4rem; }
  .prj-hero-content { padding: 24px; }
  .prj-hero-arrow { top: 24px; right: 24px; }

  /* Always show info on mobile (no hover) */
  .prj-bento-info { transform: translateY(0); opacity: 1; }
  .prj-bento-gradient { opacity: 1; }
  .prj-bento-card::after { opacity: 0; }

  .prj-filter-bar {
    justify-content: flex-start; overflow-x: auto;
    scrollbar-width: none; border-radius: 40px;
    flex-wrap: nowrap; padding: 6px;
  }
  .prj-filter-bar::-webkit-scrollbar { display: none; }
  .prj-filter { white-space: nowrap; flex-shrink: 0; padding: 8px 16px; font-size: 0.78rem; }

  .cta-card { padding: 50px 24px; }
}

@media (max-width: 480px) {
  .prj-hero-card { height: 240px; }
  .prj-hero-side { flex-direction: column; }
  .prj-side-card { height: 180px; }
  .prj-bento {
    grid-template-columns: 1fr 1fr; grid-auto-rows: 180px;
  }
  .prj-wide { grid-column: span 2; }
  .prj-hero-content h2 { font-size: 1.2rem; }
  .prj-side-content h3 { font-size: 1rem; }
  .prj-bento-info h4 { font-size: 0.88rem; }
  .prj-cat-pill { font-size: 0.6rem; padding: 3px 10px; }
}
</style>
