---
import Layout from '../../layouts/Layout.astro';
import en from '../../i18n/en.json';
const t = en;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const serviceIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m6.08 9.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/><path d="m6.08 14.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.3-2.2 1.3-2.5l13.5-4c1.1-.3 2.2.3 2.5 1.3Z"/><path d="m6.2 5.3 3.1 3.9"/><path d="m12.4 3.4 3.1 4"/><path d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="M20 12h2"/><path d="m19.07 4.93-1.41 1.41"/><path d="M15.947 12.65a4 4 0 0 0-5.925-4.128"/><path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5.5 20H8"/><path d="M17 9h.01"/><rect x="12" y="4" width="10" height="16" rx="2"/><path d="M8 6H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h4"/><circle cx="17" cy="15" r="1"/><path d="M18.5 20H21"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/><path d="M21.29 14.7a2.43 2.43 0 0 0-2.65-.52c-.3.12-.57.3-.8.53l-.34.34-.35-.34a2.43 2.43 0 0 0-2.65-.53c-.3.12-.56.3-.79.53-.95.94-1 2.53.2 3.74L17.5 22l3.6-3.55c1.2-1.21 1.14-2.8.19-3.74Z"/></svg>`
];

const serviceBullets: string[][] = [
  ["Brand positioning", "Brand building & growth", "Crisis management", "Comprehensive media strategy"],
  ["AI & smart systems", "E-commerce solutions", "Enterprise software", "IT infrastructure & security"],
  ["Advertising TVCs", "MVs & viral clips", "Digital & social media content", "Short films & brand films"],
  ["Power industry forecasts", "Aviation weather", "Agricultural forecasting", "Petroleum & maritime"],
  ["Social media management", "Advanced SEO & SEM", "Strategic content marketing", "Performance analytics"],
  ["TV & radio booking", "PR articles & press", "KOLs & Influencer marketing", "Banners, posters & OOH"],
  ["Nationwide billboards & LED", "Airport advertising", "Vehicle wraps & transit media", "Prime strategic locations"],
  ["Conferences & seminars", "Product launches", "Large-scale teambuilding", "Roadshows & activations"],
];

const accents = ["#E85A20","#635BFF","#00D4FF","#E02050","#E85A20","#635BFF","#00D4FF","#E02050"];
function hexRgba(hex: string, a: number) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${a})`;
}
const items = t.services.items;
---

<Layout lang="en">
  <section class="page-hero svc-hero">
    <div class="container">
      <p class="section-tag fade-in">{t.pageHero.services.tag}</p>
      <h1 class="section-title fade-in">{t.pageHero.services.title}</h1>
      <p class="fade-in svc-hero-sub">{t.pageHero.services.subtitle}</p>
      <div class="svc-marquee fade-in">
        <div class="svc-marquee-track">
          {[...items, ...items].map((s, i) => (
            <span class="svc-marquee-item">
              <span class="svc-marquee-dot"></span>
              {s.title}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 0: Feature Banner -->
  <section class="svc-feature" id="svc-0" style={`--accent:${accents[0]}`}>
    <img src={`${base}${items[0].img}`} alt={items[0].title} class="svc-feature-bg" loading="eager" />
    <div class="svc-feature-overlay"></div>
    <div class="container svc-feature-content fade-in">
      <div class="svc-number-light">01</div>
      <div class="svc-icon-badge-light"><div class="svc-icon-inner" set:html={serviceIcons[0]} /></div>
      <h2>{items[0].title}</h2>
      <p>{items[0].desc}</p>
      <ul class="svc-bullets-light">
        {serviceBullets[0].map(b => <li><span class="svc-bullet-dot" style={`background:${accents[0]}`}></span>{b}</li>)}
      </ul>
      <div class="svc-card-actions-light">
        {(items[0] as any).detailPage && (
          <a href={`${base}${(items[0] as any).detailPage}`} class="svc-detail-link-light">Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
        )}
        <a href={`${base}/en/contact`} class="svc-cta-light">Get Started <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
      </div>
    </div>
  </section>

  <!-- 1+2: Card Pair -->
  <section class="svc-pair svc-section-light" id="svc-1">
    <div class="container">
      <div class="svc-pair-grid">
        {[1, 2].map(i => (
          <div class="svc-card fade-in" style={`--accent:${accents[i]}`}>
            <div class="svc-card-img-wrap">
              <img src={`${base}${items[i].img}`} alt={items[i].title} loading="lazy" class="svc-card-img" />
              <div class="svc-card-number">{String(i+1).padStart(2,'0')}</div>
            </div>
            <div class="svc-card-body">
              <div class="svc-icon-badge" style={`background:${hexRgba(accents[i],0.1)};color:${accents[i]}`}>
                <div class="svc-icon-inner" set:html={serviceIcons[i]} />
              </div>
              <h3>{items[i].title}</h3>
              <p>{items[i].desc}</p>
              <ul class="svc-bullets-compact">
                {serviceBullets[i].map(b => <li><span class="svc-bullet-dot" style={`background:${accents[i]}`}></span>{b}</li>)}
              </ul>
              <div class="svc-card-actions">
                {(items[i] as any).detailPage && (
                  <a href={`${base}${(items[i] as any).detailPage}`} class="svc-detail-link" style={`--cta-color:${accents[i]}`}>Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
                )}
                <a href={`${base}/en/contact`} class="svc-cta" style={`--cta-color:${accents[i]}`}>Get Started <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3: Split -->
  <section class="svc-split svc-section-alt" id="svc-3">
    <div class="container">
      <div class="svc-split-row fade-in">
        <div class="svc-split-img"><img src={`${base}${items[3].img}`} alt={items[3].title} loading="lazy" /></div>
        <div class="svc-split-text">
          <div class="svc-number" style={`color:${accents[3]}`}>04</div>
          <div class="svc-icon-badge" style={`background:${hexRgba(accents[3],0.1)};color:${accents[3]}`}><div class="svc-icon-inner" set:html={serviceIcons[3]} /></div>
          <h2>{items[3].title}</h2>
          <p class="svc-desc">{items[3].desc}</p>
          <ul class="svc-bullets">{serviceBullets[3].map(b => <li><span class="svc-bullet-dot" style={`background:${accents[3]}`}></span>{b}</li>)}</ul>
          <div class="svc-card-actions">
            {(items[3] as any).detailPage && (
              <a href={`${base}${(items[3] as any).detailPage}`} class="svc-detail-link" style={`--cta-color:${accents[3]}`}>Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
            )}
            <a href={`${base}/en/contact`} class="svc-cta" style={`--cta-color:${accents[3]}`}>Get Started <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4: Split reversed -->
  <section class="svc-split svc-section-light" id="svc-4">
    <div class="container">
      <div class="svc-split-row svc-split-reverse fade-in">
        <div class="svc-split-img"><img src={`${base}${items[4].img}`} alt={items[4].title} loading="lazy" /></div>
        <div class="svc-split-text">
          <div class="svc-number" style={`color:${accents[4]}`}>05</div>
          <div class="svc-icon-badge" style={`background:${hexRgba(accents[4],0.1)};color:${accents[4]}`}><div class="svc-icon-inner" set:html={serviceIcons[4]} /></div>
          <h2>{items[4].title}</h2>
          <p class="svc-desc">{items[4].desc}</p>
          <ul class="svc-bullets">{serviceBullets[4].map(b => <li><span class="svc-bullet-dot" style={`background:${accents[4]}`}></span>{b}</li>)}</ul>
          <div class="svc-card-actions">
            {(items[4] as any).detailPage && (
              <a href={`${base}${(items[4] as any).detailPage}`} class="svc-detail-link" style={`--cta-color:${accents[4]}`}>Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
            )}
            <a href={`${base}/en/contact`} class="svc-cta" style={`--cta-color:${accents[4]}`}>Get Started <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5+6: Card Pair -->
  <section class="svc-pair svc-section-alt" id="svc-5">
    <div class="container">
      <div class="svc-pair-grid">
        {[5, 6].map(i => (
          <div class="svc-card fade-in" style={`--accent:${accents[i]}`}>
            <div class="svc-card-img-wrap">
              <img src={`${base}${items[i].img}`} alt={items[i].title} loading="lazy" class="svc-card-img" />
              <div class="svc-card-number">{String(i+1).padStart(2,'0')}</div>
            </div>
            <div class="svc-card-body">
              <div class="svc-icon-badge" style={`background:${hexRgba(accents[i],0.1)};color:${accents[i]}`}>
                <div class="svc-icon-inner" set:html={serviceIcons[i]} />
              </div>
              <h3>{items[i].title}</h3>
              <p>{items[i].desc}</p>
              <ul class="svc-bullets-compact">
                {serviceBullets[i].map(b => <li><span class="svc-bullet-dot" style={`background:${accents[i]}`}></span>{b}</li>)}
              </ul>
              <div class="svc-card-actions">
                {(items[i] as any).detailPage && (
                  <a href={`${base}${(items[i] as any).detailPage}`} class="svc-detail-link" style={`--cta-color:${accents[i]}`}>Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
                )}
                <a href={`${base}/en/contact`} class="svc-cta" style={`--cta-color:${accents[i]}`}>Get Started <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7: Feature Banner closing -->
  <section class="svc-feature" id="svc-7" style={`--accent:${accents[7]}`}>
    <img src={`${base}${items[7].img}`} alt={items[7].title} class="svc-feature-bg" loading="lazy" />
    <div class="svc-feature-overlay"></div>
    <div class="container svc-feature-content fade-in">
      <div class="svc-number-light">08</div>
      <div class="svc-icon-badge-light"><div class="svc-icon-inner" set:html={serviceIcons[7]} /></div>
      <h2>{items[7].title}</h2>
      <p>{items[7].desc}</p>
      <ul class="svc-bullets-light">
        {serviceBullets[7].map(b => <li><span class="svc-bullet-dot" style={`background:${accents[7]}`}></span>{b}</li>)}
      </ul>
      <div class="svc-card-actions-light">
        {(items[7] as any).detailPage && (
          <a href={`${base}${(items[7] as any).detailPage}`} class="svc-detail-link-light">Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
        )}
        <a href={`${base}/en/contact`} class="svc-cta-light">Get Started <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg></a>
      </div>
    </div>
  </section>

  <section class="section section-light contact-cta" id="services-cta">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>{t.home.contactCta}</h2>
        <p>{t.home.contactCtaSub}</p>
        <a href={`${base}/en/contact`} class="btn-glow">{t.home.contactCtaBtn}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.svc-hero { padding-bottom: 60px; }
.svc-hero-sub { font-size: 1.1rem; max-width: 600px; margin: 0 auto 32px; color: var(--color-text-dark-secondary); }
.svc-marquee {
  width: 100vw; margin-left: calc(-50vw + 50%); overflow: hidden; position: relative; margin-top: 24px;
  background: var(--color-gradient-subtle);
  border: 1px solid rgba(232, 90, 32, 0.04);
  border-radius: 16px;
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  box-shadow:
    0 4px 24px rgba(232, 90, 32, 0.05),
    0 1px 0 rgba(255, 255, 255, 0.3) inset;
  padding: 16px 0;
  -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
  mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
  transform: skewX(-2deg);
}
.svc-marquee-track {
  display: flex; gap: 0; width: max-content;
  animation: svc-scroll 28s linear infinite;
  transform: skewX(2deg);
}
.svc-marquee-item {
  display: inline-flex; align-items: center; gap: 20px;
  white-space: nowrap; font-size: 1.3rem; font-weight: 700;
  background: var(--color-gradient);
  background-size: 200% 100%;
  -webkit-background-clip: text; background-clip: text;
  -webkit-text-fill-color: transparent;
  padding: 8px 0; user-select: none; pointer-events: none;
}
.svc-marquee-dot {
  width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
  background: var(--color-gradient);
  opacity: 0.5; margin-right: 20px;
}
.svc-marquee-item:first-child .svc-marquee-dot { display: none; }
@keyframes svc-scroll {
  0% { transform: translateX(0) skewX(2deg); }
  100% { transform: translateX(-50%) skewX(2deg); }
}
.svc-section-light { background: #fff; }
.svc-section-alt { background: var(--color-bg-light); }
.svc-number { font-size: 0.8rem; font-weight: 800; letter-spacing: 3px; opacity: 0.5; margin-bottom: 8px; }
.svc-icon-badge { display: flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: 14px; margin-bottom: 20px; }
.svc-icon-inner { width: 26px; height: 26px; }
.svc-desc { font-size: 1rem; color: var(--color-text-dark-secondary); line-height: 1.8; margin-bottom: 24px; }
.svc-bullets { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 32px; }
.svc-bullets li { display: flex; align-items: center; gap: 10px; font-size: 0.9rem; font-weight: 500; color: var(--color-text-dark); }
.svc-bullet-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.svc-cta {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 0.85rem; font-weight: 600;
  color: var(--cta-color, var(--color-accent-orange));
  padding: 10px 22px; border-radius: 50px;
  border: 1.5px solid var(--cta-color, var(--color-accent-orange));
  background: transparent; transition: all var(--transition);
}
.svc-cta:hover {
  background: var(--cta-color, var(--color-accent-orange)); color: #fff;
  transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.svc-cta svg { transition: transform var(--transition); }
.svc-cta:hover svg { transform: translateX(3px); }
.svc-feature { position: relative; min-height: 520px; display: flex; align-items: center; overflow: hidden; }
.svc-feature-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.svc-feature-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(6,27,46,0.88) 0%, rgba(10,37,64,0.7) 50%, rgba(6,27,46,0.5) 100%); }
.svc-feature-content { position: relative; z-index: 2; max-width: 640px; }
.svc-feature-content h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; color: #fff; margin-bottom: 16px; }
.svc-feature-content p { color: rgba(255,255,255,0.8); font-size: 1.05rem; line-height: 1.8; margin-bottom: 24px; }
.svc-number-light { font-size: 0.8rem; font-weight: 800; letter-spacing: 3px; color: var(--accent); margin-bottom: 8px; }
.svc-icon-badge-light { display: flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: 14px; background: rgba(255,255,255,0.1); color: var(--accent); margin-bottom: 20px; backdrop-filter: blur(8px); }
.svc-bullets-light { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 32px; }
.svc-bullets-light li { display: flex; align-items: center; gap: 10px; font-size: 0.9rem; font-weight: 500; color: rgba(255,255,255,0.9); }
.svc-cta-light { display: inline-flex; align-items: center; gap: 8px; font-size: 0.92rem; font-weight: 700; color: var(--accent); transition: all var(--transition); }
.svc-cta-light:hover { gap: 12px; color: var(--accent); }
.svc-pair { padding: 80px 0; }
.svc-pair-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
.svc-card { background: #fff; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid rgba(10,37,64,0.06); box-shadow: 0 2px 12px rgba(10,37,64,0.06); transition: all 0.4s ease; }
.svc-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(10,37,64,0.12); }
.svc-section-alt .svc-card { background: #fff; }
.svc-card-img-wrap { position: relative; height: 220px; overflow: hidden; }
.svc-card-img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 20%; transition: transform 0.5s ease; }
.svc-card:hover .svc-card-img { transform: scale(1.05); }
.svc-card-number { position: absolute; top: 16px; left: 16px; font-size: 0.75rem; font-weight: 800; letter-spacing: 2px; color: #fff; background: rgba(0,0,0,0.35); backdrop-filter: blur(8px); padding: 4px 12px; border-radius: 20px; }
.svc-card-body { padding: 28px 24px; }
.svc-card-body h3 { font-size: 1.2rem; font-weight: 800; color: var(--color-text-dark); margin-bottom: 12px; }
.svc-card-body p { font-size: 0.9rem; color: var(--color-text-dark-secondary); line-height: 1.7; margin-bottom: 20px; }
.svc-bullets-compact { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 24px; }
