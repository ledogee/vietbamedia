---
import Layout from '../../../layouts/Layout.astro';
import ServiceDetail from '../../../components/ServiceDetail.astro';
import en from '../../../i18n/en.json';
const s = en.serviceDetail.events;
const t = en;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout lang="en">
  <ServiceDetail
    lang="en"
    sectionTag={s.sectionTag}
    title={s.title}
    subtitle={s.subtitle}
    intro={s.intro}
    achievements={s.achievements}
    highlights={s.highlights}
    gallery={s.gallery}
    ctaTitle={t.home.contactCta}
    ctaSub={t.home.contactCtaSub}
    ctaBtn={t.home.contactCtaBtn}
    ctaLink={`${base}/en/contact`}
  />
</Layout>
