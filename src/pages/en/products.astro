---
import Layout from '../../layouts/Layout.astro';
import en from '../../i18n/en.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout lang="en">
  <section class="pd-hero">
    <div class="pd-hero-bg-shapes">
      <div class="pd-shape pd-shape-1"></div>
      <div class="pd-shape pd-shape-2"></div>
      <div class="pd-shape pd-shape-3"></div>
    </div>
    <div class="container pd-hero-content fade-in">
      <p class="pd-tag">PRODUCT DEVELOPMENT</p>
      <h1 class="pd-title">Under Development</h1>
      <div class="pd-divider"></div>
      <p class="pd-subtitle">Vietba Group is building a new technology product ecosystem, delivering breakthrough solutions for Vietnam's media industry.</p>
      <p class="pd-coming">This page will be updated soon. Please check back later!</p>
      <div class="pd-actions">
        <a href={`${base}/en/`} class="btn-glow">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Home
        </a>
        <a href={`${base}/en/contact`} class="pd-contact-btn">
          Contact Us
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
.pd-hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--color-bg-dark); position: relative; overflow: hidden; }
.pd-hero-bg-shapes { position: absolute; inset: 0; }
.pd-shape { position: absolute; border-radius: 50%; background: radial-gradient(circle, var(--color-accent-orange), transparent 70%); opacity: 0.07; animation: pdFloat 8s ease-in-out infinite; }
.pd-shape-1 { width: 600px; height: 600px; top: -200px; right: -150px; }
.pd-shape-2 { width: 400px; height: 400px; bottom: -100px; left: -100px; animation-delay: 3s; background: radial-gradient(circle, var(--color-accent-cyan), transparent 70%); }
.pd-shape-3 { width: 300px; height: 300px; top: 50%; left: 60%; animation-delay: 5s; background: radial-gradient(circle, var(--color-accent-purple), transparent 70%); }
@keyframes pdFloat { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-30px) scale(1.05); } }
.pd-hero-content { position: relative; z-index: 2; text-align: center; max-width: 650px; }
.pd-tag { font-size: 0.82rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--color-accent-orange); margin-bottom: 20px; }
.pd-title { font-size: clamp(2.4rem, 5vw, 3.8rem); font-weight: 900; color: #fff; margin-bottom: 24px; line-height: 1.1; }
.pd-divider { width: 60px; height: 3px; margin: 0 auto 28px; background: var(--color-gradient); border-radius: 2px; }
.pd-subtitle { font-size: 1.1rem; color: var(--color-text-light-secondary); line-height: 1.8; margin-bottom: 16px; }
.pd-coming { font-size: 0.95rem; color: rgba(255,255,255,0.5); font-style: italic; margin-bottom: 40px; }
.pd-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.pd-contact-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 10px; font-weight: 700; font-size: 0.92rem; background: transparent; color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.15); transition: all var(--transition); text-decoration: none; }
.pd-contact-btn:hover { background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.3); }
</style>
