---
import Layout from '../../../layouts/Layout.astro';
import en from '../../../i18n/en.json';
const t = en;
const c = en.careers;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout lang="en" darkHero={true} heroLogo={true}>
  <!-- Full-Bleed Hero Banner -->
  <section class="rc-hero">
    <img src={`${base}${c.heroImg}`} alt="Vietba Group Careers" class="rc-hero-bg" loading="eager" />
    <div class="rc-hero-overlay"></div>
    <div class="container rc-hero-content fade-in">
      <p class="rc-hero-tag">{c.sectionTag}</p>
      <h1 class="rc-hero-title">{c.title}</h1>
      <p class="rc-hero-sub">{c.subtitle}</p>
      <a href="#rc-jobs" class="btn-glow rc-hero-cta">
        View Open Positions
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"></path></svg>
      </a>
    </div>
  </section>

  <!-- Company Introduction -->
  <section class="section section-light" id="rc-intro">
    <div class="container">
      <div class="rc-intro-grid fade-in">
        <div class="rc-intro-text">
          <p class="section-tag">{c.sectionTag}</p>
          <h2 class="rc-section-title">About Vietba Group</h2>
          <p class="rc-intro-p">{c.intro}</p>
          <p class="rc-intro-p" style="margin-top:16px">{c.introSub}</p>
          <ul class="rc-service-list">
            {c.introServices.map(s => <li><span class="rc-check"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></span>{s}</li>)}
          </ul>
          <p class="rc-intro-p rc-intro-achievement">{c.introAchievements}</p>
        </div>
        <div class="rc-intro-images">
          {c.introImages.map((img, i) => (
            <div class={`rc-intro-img-cell ${i === 0 ? 'rc-intro-img-large' : ''}`}>
              <img src={`${base}${img}`} alt={`Vietba Group ${i + 1}`} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Job Listings -->
  <section class="section rc-jobs-section" id="rc-jobs">
    <div class="container">
      <div class="section-header fade-in">
        <p class="section-tag">{c.sectionTag}</p>
        <h2 class="section-title">{c.listTitle}</h2>
      </div>
      <div class="rc-jobs-grid">
        {c.jobs.map((job, i) => (
          <a href={`${base}/en/careers/${job.slug}`} class="rc-job-card fade-in" style={`--delay:${i * 80}ms`}>
            <div class="rc-job-card-accent"></div>
            <div class="rc-job-card-body">
              <div class="rc-job-meta">
                <span class="rc-job-type">{job.type}</span>
                <span class="rc-job-location">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {job.location}
                </span>
              </div>
              <h3 class="rc-job-title">{job.title}</h3>
              <p class="rc-job-summary">{job.summary}</p>
              <span class="rc-view-detail">
                {c.viewDetail}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-light contact-cta" id="rc-cta">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>{t.home.contactCta}</h2>
        <p>{t.home.contactCtaSub}</p>
        <a href={`${base}/en/contact`} class="btn-glow">{t.home.contactCtaBtn}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.rc-hero { position: relative; min-height: 560px; display: flex; align-items: center; overflow: hidden; }
.rc-hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
.rc-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(6,27,46,0.88) 0%, rgba(10,37,64,0.72) 50%, rgba(6,27,46,0.55) 100%); }
.rc-hero-content { position: relative; z-index: 2; max-width: 700px; text-align: left; }
.rc-hero-tag { display: inline-block; font-size: 0.85rem; font-weight: 700; letter-spacing: 3px; color: var(--color-accent-orange); margin-bottom: 16px; }
.rc-hero-title { font-size: clamp(2.2rem, 5vw, 3.6rem); font-weight: 900; color: #fff; margin-bottom: 20px; line-height: 1.15; }
.rc-hero-sub { font-size: 1.15rem; color: rgba(255,255,255,0.82); line-height: 1.8; margin-bottom: 36px; max-width: 560px; }
.rc-hero-cta { box-shadow: 0 0 40px var(--color-glow-orange), 0 4px 20px rgba(0,0,0,0.3); }
.rc-intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
.rc-section-title { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 800; color: var(--color-text-dark); margin-bottom: 20px; }
.rc-intro-p { font-size: 0.95rem; color: var(--color-text-dark-secondary); line-height: 1.85; }
.rc-intro-achievement { margin-top: 20px; padding: 20px; border-left: 3px solid var(--color-accent-orange); background: rgba(255,107,53,0.04); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; font-style: italic; }
.rc-service-list { list-style: none; display: grid; grid-template-columns: 1fr; gap: 10px; margin: 20px 0; }
.rc-service-list li { display: flex; align-items: center; gap: 10px; font-size: 0.88rem; font-weight: 500; color: var(--color-text-dark); }
.rc-check { color: var(--color-accent-orange); flex-shrink: 0; }
.rc-intro-images { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.rc-intro-img-large { grid-column: 1 / -1; }
.rc-intro-img-cell { border-radius: var(--radius-md); overflow: hidden; box-shadow: 0 4px 16px rgba(10,37,64,0.08); }
.rc-intro-img-cell img { width: 100%; height: 220px; object-fit: cover; display: block; transition: transform 0.5s ease; }
.rc-intro-img-large img { height: 280px; }
.rc-intro-img-cell:hover img { transform: scale(1.05); }
.rc-jobs-section { background: var(--color-bg-light); }
.rc-jobs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.rc-job-card { display: block; background: #fff; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid rgba(10,37,64,0.06); box-shadow: 0 2px 12px rgba(10,37,64,0.06); transition: all 0.4s ease; text-decoration: none; position: relative; animation-delay: var(--delay); }
.rc-job-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(10,37,64,0.12); border-color: rgba(255,107,53,0.2); }
.rc-job-card-accent { height: 4px; background: var(--color-gradient); }
.rc-job-card-body { padding: 28px; }
.rc-job-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
.rc-job-type { font-size: 0.72rem; font-weight: 700; letter-spacing: 1px; color: var(--color-accent-orange); background: rgba(255,107,53,0.08); padding: 4px 12px; border-radius: 50px; }
.rc-job-location { display: inline-flex; align-items: center; gap: 4px; font-size: 0.78rem; color: var(--color-text-dark-secondary); font-weight: 500; }
.rc-job-title { font-size: 1.15rem; font-weight: 800; color: var(--color-text-dark); margin-bottom: 12px; line-height: 1.3; }
.rc-job-summary { font-size: 0.88rem; color: var(--color-text-dark-secondary); line-height: 1.7; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.rc-view-detail { display: inline-flex; align-items: center; gap: 6px; font-size: 0.88rem; font-weight: 700; color: var(--color-accent-orange); transition: all var(--transition); }
.rc-job-card:hover .rc-view-detail { gap: 10px; }
.rc-view-detail svg { transition: transform var(--transition); }
.rc-job-card:hover .rc-view-detail svg { transform: translateX(4px); }
.cta-card { text-align: center; padding: 80px 40px; background: var(--color-gradient); border-radius: var(--radius-lg); position: relative; overflow: hidden; }
.cta-card::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.12) 0%, transparent 60%); pointer-events: none; }
.cta-card h2 { font-size: clamp(1.6rem, 3.5vw, 2.5rem); font-weight: 800; color: #fff; margin-bottom: 16px; position: relative; }
.cta-card p { color: rgba(255,255,255,0.85); font-size: 1.05rem; max-width: 550px; margin: 0 auto 32px; position: relative; }
.cta-card .btn-glow { position: relative; background: #fff; color: var(--color-accent-orange); }
@media (max-width: 768px) {
  .rc-hero { min-height: 440px; }
  .rc-intro-grid { grid-template-columns: 1fr; gap: 32px; }
  .rc-jobs-grid { grid-template-columns: 1fr; }
  .cta-card { padding: 50px 24px; }
}
</style>
