---
import Layout from '../../layouts/Layout.astro';
import en from '../../i18n/en.json';
const t = en;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Icons for services
const serviceIcons: Record<string, string> = {
  content: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  digital: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20V10M6 20V4M18 20v-6"/></svg>`,
  booking: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>`,
  event: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>`,
  ooh: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="2"/><path d="M7 7h10M7 12h10M7 17h5"/></svg>`,
};

// Strength icons
const strengthIcons: Record<string, string> = {
  media: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="24" cy="24" r="20"/><polygon points="20,16 20,32 34,24" fill="currentColor" stroke="none"/></svg>`,
  tech: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="8" y="8" width="32" height="32" rx="4"/><path d="M16 20l4 4-4 4M24 28h8"/></svg>`,
};

// Service items for media services section
const mediaServices = [
  { key: 'content', title: 'Multi-Platform Content', desc: 'Professional content production for television, digital and social media.', icon: serviceIcons.content },
  { key: 'digital', title: 'Digital Marketing', desc: 'Comprehensive digital marketing strategies, SEO, SEM and content marketing.', icon: serviceIcons.digital },
  { key: 'booking', title: 'Media Booking', desc: 'TV, radio, press, PR, KOLs and media channel booking services.', icon: serviceIcons.booking },
  { key: 'event', title: 'Event Organization', desc: 'Professional events from conferences and launches to large-scale teambuilding.', icon: serviceIcons.event },
  { key: 'ooh', title: 'Outdoor Advertising (OOH)', desc: 'Strategic OOH advertising at prime locations nationwide.', icon: serviceIcons.ooh },
];

const partners = [
  { name: 'Samsung', mono: '/images/partners/mono/samsung.png', color: '/images/partners/color/samsung.png' },
  { name: 'Pepsi', mono: '/images/partners/mono/pepsi.png', color: '/images/partners/color/pepsi.png' },
  { name: 'Vietcombank', mono: '/images/partners/mono/vietcombank.png', color: '/images/partners/color/vietcombank.png' },
  { name: 'USAID', mono: '/images/partners/mono/usaid.png', color: '/images/partners/color/usaid.png' },
  { name: 'Bamboo Airways', mono: '/images/partners/mono/bamboo-airways.png', color: '/images/partners/color/bamboo-airways.png' },
  { name: 'Viettel', mono: '/images/partners/mono/viettel.png', color: '/images/partners/color/viettel.png' },
  { name: 'Vietinbank', mono: '/images/partners/mono/vietinbank.png', color: '/images/partners/color/vietinbank.png' },
  { name: 'RMIT', mono: '/images/partners/mono/rmit.png', color: '/images/partners/color/rmit.png' },
  { name: 'GroupM', mono: '/images/partners/mono/groupm.png', color: '/images/partners/color/groupm.png' },
  { name: 'Habeco', mono: '/images/partners/mono/habeco.png', color: '/images/partners/color/habeco.png' },
  { name: 'Pharmaton', mono: '/images/partners/mono/pharmaton.png', color: '/images/partners/color/pharmaton.png' },
  { name: 'Petrovietnam', mono: '/images/partners/mono/petrovietnam.png', color: '/images/partners/color/petrovietnam.png' },
  { name: 'Qatar Airways', mono: '/images/partners/mono/qatar-airways.png', color: '/images/partners/color/qatar-airways.png' },
  { name: 'SABECO', mono: '/images/partners/mono/sabeco.png', color: '/images/partners/color/sabeco.png' },
  { name: 'Sea Links', mono: '/images/partners/mono/sealinks.png', color: '/images/partners/color/sealinks.png' },
  { name: 'Vietbank', mono: '/images/partners/mono/vietbank.png', color: '/images/partners/color/vietbank.png' },
  { name: 'Vinacafe', mono: '/images/partners/mono/vinacafe.png', color: '/images/partners/color/vinacafe.png' },
  { name: 'Vinaphone', mono: '/images/partners/mono/vinaphone.png', color: '/images/partners/color/vinaphone.png' },
];
---

<Layout lang="en">
  <!-- 1. Hero — White with Interactive Background -->
  <section class="hero-white" id="hero">
    <div class="container hero-content">
      <p class="hero-tag fade-in">{t.about.sectionTag}</p>
      <h1 class="hero-title fade-in">
        {t.hero.title}<br/><span class="hero-title-gradient">{t.hero.titleHighlight}</span>
      </h1>
      <p class="hero-subtitle fade-in">{t.hero.subtitle}</p>
      <div class="hero-buttons fade-in">
        <a href={`${base}/en/contact`} class="btn-glow">{t.hero.cta}</a>
        <a href={`${base}/en/about`} class="btn-outline">{t.nav.about}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <div class="hero-accent hero-accent-1" aria-hidden="true"></div>
    <div class="hero-accent hero-accent-2" aria-hidden="true"></div>
    <div class="hero-accent hero-accent-3" aria-hidden="true"></div>
  </section>

  <!-- 2. Company Introduction (Light background) -->
  <section class="section section-light" id="about-intro">
    <div class="container">
      <div class="intro-grid fade-in">
        <div class="intro-text">
          <p class="section-tag">{t.about.sectionTag}</p>
          <h2 class="section-title">{t.about.title}</h2>
          <p class="intro-desc">{t.about.description}</p>
          <p class="intro-desc" style="margin-top:12px">{t.about.description2}</p>
          <div class="intro-buttons">
            <a href={`${base}/en/about`} class="btn-outline">{t.nav.about}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
        <div class="intro-stats">
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-number" data-target="26">0</span>
              <div class="stat-label-group">
                <span>{t.about.stats.yearsLabel1}</span>
                <span>{t.about.stats.yearsLabel2}</span>
              </div>
            </div>
            <div class="stat-card">
              <span class="stat-number" data-target="8">0</span>
              <div class="stat-label-group">
                <span>{t.about.stats.fieldsLabel1}</span>
                <span>{t.about.stats.fieldsLabel2}</span>
              </div>
            </div>
            <div class="stat-card">
              <span class="stat-number" data-target="+2K">0</span>
              <div class="stat-label-group">
                <span>{t.about.stats.partnersLabel1}</span>
                <span>{t.about.stats.partnersLabel2}</span>
              </div>
            </div>
            <div class="stat-card">
              <span class="stat-number" data-target="+5K">0</span>
              <div class="stat-label-group">
                <span>{t.about.stats.projectsLabel1}</span>
                <span>{t.about.stats.projectsLabel2}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Logo Marquee -->
  <section class="section section-light partners-section" id="partners-marquee">
    <div class="container">
      <div class="section-header fade-in">
        <p class="section-tag">{t.home.partnersTeaser}</p>
      </div>
    </div>
    <div class="marquee-viewport fade-in">
      <div class="marquee-track" id="marqueeTrack">
        {partners.map((p) => (
          <button class="partner-logo-btn" type="button" aria-label={p.name}>
            <img src={`${base}${p.mono}`} alt={p.name} class="partner-img partner-img--mono" loading="lazy" />
            <img src={`${base}${p.color}`} alt="" class="partner-img partner-img--color" loading="lazy" />
          </button>
        ))}
        {partners.map((p) => (
          <button class="partner-logo-btn" type="button" aria-label={p.name}>
            <img src={`${base}${p.mono}`} alt={p.name} class="partner-img partner-img--mono" loading="lazy" />
            <img src={`${base}${p.color}`} alt="" class="partner-img partner-img--color" loading="lazy" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Strengths (Dark navy) -->
  <section class="section section-dark" id="strengths">
    <div class="container">
      <div class="section-header fade-in">
        <p class="section-tag">{t.strengths.sectionTag}</p>
        <h2 class="section-title">{t.strengths.title}</h2>
      </div>
      <div class="strengths-grid">
        {t.strengths.items.map((item, i) => (
          <div class="strength-card fade-in">
            <div class="strength-icon-wrapper">
              <div class={`strength-icon ${i === 0 ? 'orange' : 'purple'}`} set:html={strengthIcons[item.icon]} />
            </div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <div class={`strength-accent ${i === 0 ? 'orange' : 'purple'}`}></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Media Services (Light background) -->
  <section class="section section-light" id="services-teaser">
    <div class="container">
      <div class="section-header fade-in">
        <p class="section-tag">{t.home.servicesTeaser}</p>
        <h2 class="section-title">{t.services.title}</h2>
      </div>
      <div class="services-grid">
        {mediaServices.map((s) => (
          <div class="service-card fade-in">
            <div class="service-icon-wrap">
              <div class="service-icon" set:html={s.icon} />
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="teaser-action fade-in">
        <a href={`${base}/en/services`} class="view-all-link">
          {t.home.viewAll}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. Timeline (Dark navy) -->
  <section class="section section-dark" id="timeline-teaser" style="background:var(--color-bg-dark)">
    <div class="container">
      <div class="section-header fade-in">
        <p class="section-tag">{t.home.timelineTeaser}</p>
        <h2 class="section-title">{t.timeline.title}</h2>
      </div>
      <div class="timeline-mini fade-in">
        <div class="timeline-mini-line"></div>
        {t.timeline.items.map((item, i) => (
          <div class={`timeline-mini-node ${i === 0 ? 'active' : ''}`}>
            <span class="mini-year">{item.year}</span>
            <div class="mini-dot"></div>
            <span class="mini-title">{item.title}</span>
          </div>
        ))}
      </div>
      <div class="teaser-action fade-in">
        <a href={`${base}/en/history`} class="btn-outline">
          {t.home.exploreHistory}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 6. Contact CTA -->
  <section class="section section-light contact-cta" id="contact-cta">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>{t.home.contactCta}</h2>
        <p>{t.home.contactCtaSub}</p>
        <a href={`${base}/en/contact`} class="btn-glow">{t.home.contactCtaBtn}</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const counters = document.querySelectorAll('.stat-number');
  const cObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = el.dataset.target || '0';
        const match = target.match(/^([+]?)(\d+)([K+]*)$/i);
        if (!match) { el.textContent = target; return; }
        const prefix = match[1];
        const num = parseInt(match[2]);
        const suffix = match[3];
        let current = 0;
        const step = Math.max(1, Math.ceil(num / 50));
        const timer = setInterval(() => {
          current += step;
          if (current >= num) { current = num; clearInterval(timer); }
          el.textContent = prefix + current + suffix;
        }, 25);
        cObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });
  counters.forEach(c => cObserver.observe(c));

  // Partner logo marquee interaction
  document.querySelectorAll('.partner-logo-btn').forEach(btn => {
    btn.addEventListener('click', () => btn.classList.toggle('active'));
  });
  const track = document.getElementById('marqueeTrack');
  if (track) {
    track.addEventListener('mouseenter', () => track.style.animationPlayState = 'paused');
    track.addEventListener('mouseleave', () => track.style.animationPlayState = 'running');
  }
</script>

<style>
/* ─── Hero White ─── */
.hero-white { min-height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; padding: 100px 0 60px; }
.hero-content { text-align: center; position: relative; z-index: 2; }
.hero-tag { display: inline-block; font-size: 0.75rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; background: var(--color-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 20px; }
.hero-title { font-size: clamp(2.4rem, 6vw, 4.5rem); font-weight: 900; line-height: 1.08; color: var(--color-text-dark); margin-bottom: 28px; letter-spacing: -1px; }
.hero-title-gradient { background: var(--color-gradient-hero); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero-subtitle { font-size: clamp(1rem, 2vw, 1.2rem); max-width: 560px; margin: 0 auto 44px; color: var(--color-text-dark-secondary); line-height: 1.7; }
.hero-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.hero-accent { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(80px); opacity: 0.35; animation: accentFloat 8s ease-in-out infinite alternate; }
.hero-accent-1 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(255,107,53,0.4), transparent 70%); top: -10%; right: -5%; }
.hero-accent-2 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(99,91,255,0.35), transparent 70%); bottom: -5%; left: -8%; animation-delay: -3s; }
.hero-accent-3 { width: 250px; height: 250px; background: radial-gradient(circle, rgba(0,212,255,0.3), transparent 70%); top: 30%; left: 50%; transform: translateX(-50%); animation-delay: -5s; animation-name: accentFloat3; }
@keyframes accentFloat { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(20px,-15px) scale(1.1); } }
@keyframes accentFloat3 { 0% { transform: translateX(-50%) translate(0,0) scale(1); } 100% { transform: translateX(-50%) translate(-15px,20px) scale(1.15); } }
/* Styles are identical to Vietnamese index — they share the same global.css */
.intro-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 60px; align-items: center; }
.intro-text .section-tag { margin-bottom: 16px; }
.intro-text .section-title { color: var(--color-text-dark); margin-bottom: 24px; }
.intro-desc { font-size: 1.02rem; line-height: 1.8; color: var(--color-text-dark-secondary); }
.intro-buttons { margin-top: 32px; }
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.stat-card { display: flex; align-items: center; gap: 14px; padding: 24px; background: #FFFFFF; border: 1px solid rgba(10,37,64,0.06); border-radius: var(--radius-md); transition: all var(--transition); box-shadow: 0 1px 3px rgba(10,37,64,0.06); }
.stat-card:hover { box-shadow: 0 8px 24px rgba(255,107,53,0.1); transform: translateY(-2px); border-color: rgba(255,107,53,0.2); }
.stat-number { font-size: clamp(2.5rem,5vw,3.5rem); font-weight: 300; line-height: 1; color: var(--color-text-dark); letter-spacing: -2px; }
.stat-label-group { display: flex; flex-direction: column; }
.stat-label-group span { font-size: 0.68rem; font-weight: 600; letter-spacing: 1.5px; color: var(--color-text-dark-secondary); line-height: 1.4; text-transform: uppercase; }

.strengths-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
.strength-card { position: relative; padding: 48px 36px; background: var(--color-bg-glass); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid var(--color-border-glass); border-radius: var(--radius-lg); transition: all var(--transition); overflow: hidden; }
.strength-card:hover { transform: translateY(-6px); border-color: rgba(255,107,53,0.3); box-shadow: 0 0 40px var(--color-glow-orange), 0 12px 40px rgba(0,0,0,0.3); }
.strength-card:nth-child(2):hover { border-color: rgba(99,91,255,0.3); box-shadow: 0 0 40px var(--color-glow-purple), 0 12px 40px rgba(0,0,0,0.3); }
.strength-icon-wrapper { margin-bottom: 24px; }
.strength-icon { width: 56px; height: 56px; }
.strength-icon.orange { color: var(--color-accent-orange); }
.strength-icon.purple { color: var(--color-accent-purple); }
.strength-card h3 { font-size: 1.3rem; margin-bottom: 16px; color: var(--color-text-primary); }
.strength-card p { font-size: 0.95rem; line-height: 1.8; color: var(--color-text-secondary); }
.strength-accent { position: absolute; top: 0; left: 0; right: 0; height: 3px; }
.strength-accent.orange { background: linear-gradient(90deg, #FF6B35, #FF3864); }
.strength-accent.purple { background: linear-gradient(90deg, #635BFF, #00D4FF); }

.services-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
.service-card { padding: 32px 20px; background: #FFFFFF; border: 1px solid rgba(10,37,64,0.06); border-radius: var(--radius-md); transition: all var(--transition); box-shadow: 0 1px 3px rgba(10,37,64,0.06); text-align: center; }
.service-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(255,107,53,0.12), 0 4px 16px rgba(0,0,0,0.05); border-color: rgba(255,107,53,0.2); }
.service-icon-wrap { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; margin: 0 auto 20px; background: linear-gradient(135deg, rgba(255,107,53,0.1), rgba(99,91,255,0.08)); border-radius: 14px; }
.service-icon { width: 28px; height: 28px; color: var(--color-accent-orange); }
.service-card h3 { font-size: 0.95rem; margin-bottom: 10px; color: var(--color-text-dark); }
.service-card p { font-size: 0.82rem; color: var(--color-text-dark-secondary); line-height: 1.6; }

/* ─── Partner Marquee ─── */
.partners-section { padding: 60px 0 40px; overflow: hidden; }
.partners-section .section-header { margin-bottom: 32px; }
.marquee-viewport {
  width: 100%;
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
}
.marquee-track {
  display: flex;
  align-items: center;
  gap: 48px;
  width: max-content;
  animation: marqueeScroll 45s linear infinite;
}
@keyframes marqueeScroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.partner-logo-btn {
  flex-shrink: 0;
  position: relative;
  width: 200px;
  height: 90px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  transition: transform 0.3s ease;
}
.partner-logo-btn:hover { transform: scale(1.12); }
.partner-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: opacity 0.4s ease;
}
.partner-img--mono { opacity: 0.45; filter: grayscale(100%); }
.partner-img--color { opacity: 0; }
.partner-logo-btn:hover .partner-img--mono { opacity: 0.15; }
.partner-logo-btn:hover .partner-img--color { opacity: 0.85; }
.partner-logo-btn.active .partner-img--mono { opacity: 0; }
.partner-logo-btn.active .partner-img--color { opacity: 1; }
.partner-logo-btn.active:hover .partner-img--color { opacity: 1; }

.teaser-action { text-align: center; margin-top: 40px; }
.section-light .view-all-link { color: var(--color-accent-orange); }
.section-light .view-all-link:hover { color: var(--color-accent-pink); }

.timeline-mini { position: relative; display: flex; align-items: center; justify-content: space-between; padding: 60px 20px 40px; overflow-x: auto; scrollbar-width: none; }
.timeline-mini::-webkit-scrollbar { display: none; }
.timeline-mini-line { position: absolute; top: 50%; left: 20px; right: 20px; height: 2px; background: var(--color-gradient); transform: translateY(-50%); opacity: 0.5; }
.timeline-mini-node { display: flex; flex-direction: column; align-items: center; gap: 8px; position: relative; z-index: 1; min-width: 80px; }
.mini-dot { width: 14px; height: 14px; border-radius: 50%; background: var(--color-bg-elevated); border: 2px solid var(--color-accent-orange); transition: all var(--transition); }
.timeline-mini-node.active .mini-dot { background: var(--color-accent-orange); box-shadow: 0 0 12px var(--color-glow-orange); }
.mini-year { font-size: 0.75rem; font-weight: 800; color: var(--color-accent-orange); }
.mini-title { font-size: 0.68rem; color: var(--color-text-muted); text-align: center; max-width: 90px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.contact-cta { padding: 80px 0; }
.cta-card { text-align: center; padding: 60px 40px; background: linear-gradient(135deg, rgba(255,107,53,0.06), rgba(99,91,255,0.04)); border: 1px solid rgba(255,107,53,0.15); border-radius: var(--radius-lg); }
.cta-card h2 { font-size: 1.8rem; margin-bottom: 16px; color: var(--color-text-dark); }
.cta-card p { max-width: 500px; margin: 0 auto 32px; color: var(--color-text-dark-secondary); }

@media (max-width: 1024px) { .services-grid { grid-template-columns: repeat(3, 1fr); } .strengths-grid { gap: 24px; } }
@media (max-width: 768px) {
