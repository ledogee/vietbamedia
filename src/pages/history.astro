---
import Layout from '../layouts/Layout.astro';
import vi from '../i18n/vi.json';
const t = vi;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const milestoneIcons: Record<string, string> = {
  '1999': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/></svg>`,
  '2001': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  '2007': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>`,
  '2009': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20V10M6 20V4M18 20v-6"/></svg>`,
  '2012': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
  '2014': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>`,
  '2015': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M12 17v4M7 21h10"/><path d="M9 10l2 2 4-4"/></svg>`,
  '2022': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
};

const roadPath = "M500,50 C500,150 580,180 580,250 C580,400 420,400 420,550 C420,700 640,700 640,850 C640,1000 360,1000 360,1150 C360,1300 680,1300 680,1450 C680,1600 320,1600 320,1750 C320,1900 700,1900 700,2050 C700,2200 300,2200 300,2350 Q300,2500 500,2550";

const pinPositions = [
  { x: 58, y: 250 },
  { x: 42, y: 550 },
  { x: 64, y: 850 },
  { x: 36, y: 1150 },
  { x: 68, y: 1450 },
  { x: 32, y: 1750 },
  { x: 70, y: 2050 },
  { x: 30, y: 2350 },
];
---

<Layout lang="vi">
  <!-- Immersive Hero -->
  <section class="history-hero">
    <div class="history-hero-bg" aria-hidden="true">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
    </div>
    <div class="container history-hero-content">
      <p class="section-tag fade-in">{t.pageHero.history.tag}</p>
      <h1 class="section-title fade-in">{t.pageHero.history.title}</h1>
      <p class="history-hero-sub fade-in">{t.pageHero.history.subtitle}</p>
      <div class="history-stats fade-in">
        <div class="history-stat">
          <span class="history-stat-num" data-target="27">0</span>
          <span class="history-stat-label">Năm Kinh Nghiệm</span>
        </div>
        <div class="history-stat-divider"></div>
        <div class="history-stat">
          <span class="history-stat-num" data-target="8">0</span>
          <span class="history-stat-label">Cột Mốc Quan Trọng</span>
        </div>
        <div class="history-stat-divider"></div>
        <div class="history-stat">
          <span class="history-stat-num" data-target="3">0</span>
          <span class="history-stat-label">Văn Phòng Toàn Quốc</span>
        </div>
      </div>
    </div>
    <a href="#roadmap" class="hero-scroll-hint fade-in" aria-label="Scroll to roadmap">
      <span>Khám phá hành trình</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </a>
  </section>

  <!-- Roadmap Timeline -->
  <section id="roadmap" class="section roadmap-section" style="background:#fff">
    <div class="container">
      <div class="vtl-header fade-in">
        <p class="section-tag">{t.timeline.sectionTag}</p>
        <h2 class="section-title">{t.timeline.title}</h2>
      </div>
    </div>

    <div class="roadmap-wrap">
      <div class="roadmap-container">
        <!-- SVG Road -->
        <svg class="roadmap-svg" viewBox="0 0 1000 2600" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <defs>
            <linearGradient id="roadGlow" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#E85A20" stop-opacity="0.4"/>
              <stop offset="50%" stop-color="#635BFF" stop-opacity="0.3"/>
              <stop offset="100%" stop-color="#00D4FF" stop-opacity="0.4"/>
            </linearGradient>
            <filter id="roadShadow">
              <feDropShadow dx="0" dy="0" stdDeviation="8" flood-color="#E85A20" flood-opacity="0.15"/>
            </filter>
          </defs>
          <!-- Road glow -->
          <path d={roadPath} stroke="url(#roadGlow)" stroke-width="100" fill="none" stroke-linecap="round" opacity="0.3"/>
          <!-- Road surface -->
          <path d={roadPath} stroke="#e8ecf1" stroke-width="72" fill="none" stroke-linecap="round"/>
          <!-- Road edges -->
          <path d={roadPath} stroke="rgba(0,0,0,0.06)" stroke-width="74" fill="none" stroke-linecap="round"/>
          <path d={roadPath} stroke="#e8ecf1" stroke-width="70" fill="none" stroke-linecap="round"/>
          <!-- Road center dashes -->
          <path d={roadPath} stroke="rgba(0,0,0,0.1)" stroke-width="2" fill="none" stroke-dasharray="16 12" stroke-linecap="round"/>
          <!-- Progress glow (fills the road surface) -->
          <path id="roadProgress" d={roadPath} stroke="url(#roadGlow)" stroke-width="68" fill="none" stroke-linecap="round" opacity="0.6"
            stroke-dasharray="0 99999"/>
        </svg>

        <!-- Milestone pins and cards -->
        {t.timeline.items.map((item, i) => {
          const pos = pinPositions[i];
          const isRight = pos.x > 50;
          const svgH = 2600;
          const topPct = (pos.y / svgH) * 100;
          return (
            <div class={`rm-milestone ${isRight ? 'rm-right' : 'rm-left'}`}
                 style={`top:${topPct}%`} data-index={i}>
              <!-- Pin -->
              <div class="rm-pin-wrap" style={`left:${pos.x}%`}>
                <div class={`rm-pin ${i % 2 === 0 ? 'rm-pin-orange' : 'rm-pin-purple'}`}>
                  <svg class="rm-pin-shape" viewBox="0 0 40 52" fill="none">
                    <path d="M20 0C9 0 0 8.5 0 19c0 14 20 33 20 33s20-19 20-33C40 8.5 31 0 20 0z" fill="currentColor"/>
                    <circle cx="20" cy="19" r="11" fill="#0c2036"/>
                  </svg>
                  <div class="rm-pin-icon" set:html={milestoneIcons[item.year] || milestoneIcons['1999']} />
                </div>
              </div>
              <!-- Card -->
              <div class="rm-card glass-card">
                <div class="rm-card-accent" aria-hidden="true"></div>
                <div class="rm-card-header">
                  <span class="rm-card-step">{`${String(i + 1).padStart(2, '0')} / ${String(t.timeline.items.length).padStart(2, '0')}`}</span>
                  <span class="rm-card-year gradient-text">{item.year}</span>
                </div>
                <h3 class="rm-card-title">{item.title}</h3>
                <p class="rm-card-desc">{item.desc}</p>
                <div class="rm-card-deco" aria-hidden="true">
                  <span class="rm-deco-line"></span>
                  <span class="rm-deco-diamond"></span>
                  <span class="rm-deco-line"></span>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-light history-cta">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>Sẵn sàng hợp tác?</h2>
        <p>Hãy kết nối với chúng tôi để cùng xây dựng chiến dịch truyền thông hiệu quả.</p>
        <a href={`${base}/contact`} class="btn-glow">Liên Hệ Ngay</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Counter animation
  const counters = document.querySelectorAll('.history-stat-num');
  const cObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        let current = 0;
        const step = Math.max(1, Math.ceil(target / 40));
        const timer = setInterval(() => {
          current += step;
          if (current >= target) { current = target; clearInterval(timer); }
          el.textContent = String(current);
        }, 30);
        cObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });
  counters.forEach((c) => cObserver.observe(c));

  // Scroll hint — fast scroll to roadmap
  const scrollHint = document.querySelector('.hero-scroll-hint');
  scrollHint?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('roadmap')?.scrollIntoView({ behavior: 'smooth' });
    history.replaceState(null, '', window.location.pathname);
  });

  // Scroll-reveal milestones with staggered pop-up
  const milestones = document.querySelectorAll('.rm-milestone');
  const mObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        // Stagger: pin pops first, card follows
        el.classList.add('visible');
        mObserver.unobserve(el);
      }
    });
  }, { threshold: 0, rootMargin: '0px 0px -25% 0px' });
  milestones.forEach((m) => mObserver.observe(m));

  // Smooth road progress with lerp
  const roadProgress = document.getElementById('roadProgress') as SVGPathElement | null;
  const roadmapContainer = document.querySelector('.roadmap-container') as HTMLElement;

  if (roadProgress && roadmapContainer) {
    const totalLen = roadProgress.getTotalLength();
    roadProgress.style.strokeDasharray = `${totalLen}`;
    roadProgress.style.strokeDashoffset = `${totalLen}`;

    let currentOffset = totalLen;
    let targetOffset = totalLen;
    let rafId = 0;

    function getTargetOffset() {
      const rect = roadmapContainer.getBoundingClientRect();
      const viewH = window.innerHeight;
      const start = rect.top + window.scrollY;
      const end = start + rect.height;
      const scroll = window.scrollY + viewH * 0.5;
      const pct = Math.min(1, Math.max(0, (scroll - start) / (end - start)));
      return totalLen * (1 - pct);
    }

    function animateProgress() {
      currentOffset += (targetOffset - currentOffset) * 0.35;
      // Snap when close enough
      if (Math.abs(currentOffset - targetOffset) < 0.5) currentOffset = targetOffset;
      roadProgress!.style.strokeDashoffset = String(currentOffset);
      if (currentOffset !== targetOffset) {
        rafId = requestAnimationFrame(animateProgress);
      }
    }

    window.addEventListener('scroll', () => {
      targetOffset = getTargetOffset();
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(animateProgress);
    }, { passive: true });

    targetOffset = getTargetOffset();
    currentOffset = targetOffset;
    roadProgress.style.strokeDashoffset = String(currentOffset);
  }
</script>

<style is:global>
html, body { scroll-snap-type: y proximity; }
</style>
<style>
/* ─── History Hero ─── */
.history-hero {
  position: relative; min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; padding: 140px 0 80px; background: #f8f9fb;
  scroll-snap-align: start;
}
.history-hero-bg { position: absolute; inset: 0; pointer-events: none; }
.hero-orb {
  position: absolute; border-radius: 50%;
  filter: blur(120px); opacity: 0.25;
  animation: orbFloat 10s ease-in-out infinite alternate;
}
.hero-orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(232, 90, 32,0.5), transparent 70%); top: -15%; right: -10%; }
.hero-orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(99,91,255,0.4), transparent 70%); bottom: -10%; left: -5%; animation-delay: -4s; }
.hero-orb-3 { width: 300px; height: 300px; background: radial-gradient(circle, rgba(0,212,255,0.35), transparent 70%); top: 40%; left: 45%; animation-delay: -7s; }
@keyframes orbFloat { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(25px,-20px) scale(1.12); } }

.history-hero-content { position: relative; z-index: 2; text-align: center; }
.history-hero h1 { color: #1a1a2e; font-size: clamp(2.2rem, 5vw, 3.5rem); }
.history-hero-sub { font-size: 1.1rem; max-width: 560px; margin: 0 auto 48px; color: #555; line-height: 1.7; }

.history-stats {
  display: flex; align-items: center; justify-content: center; gap: 40px;
  padding: 32px 48px; background: rgba(255,255,255,0.8); backdrop-filter: blur(20px);
  border: 1px solid rgba(0,0,0,0.08); border-radius: var(--radius-lg);
  max-width: 680px; margin: 0 auto; box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}
.history-stat { display: flex; flex-direction: column; align-items: center; gap: 6px; }
.history-stat-num { font-size: 2.8rem; font-weight: 900; background: var(--color-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1; }
.history-stat-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 1.5px; color: #888; }
.history-stat-divider { width: 1px; height: 48px; background: rgba(0,0,0,0.1); }

.hero-scroll-hint {
  position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  color: #666; font-size: 0.82rem; font-weight: 500; letter-spacing: 2px;
  animation: scrollBounce 2s ease-in-out infinite;
  cursor: pointer;
}
@keyframes scrollBounce { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(6px); } }

/* ─── Roadmap Section ─── */
.roadmap-section { padding: 100px 0 120px; overflow: hidden; background: #fff; }

.vtl-header { text-align: center; margin-bottom: 60px; }

.roadmap-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px;
}

.roadmap-container {
  position: relative;
  /* aspect ratio matches SVG viewBox 1000:2600 */
  padding-bottom: 260%;
}

.roadmap-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* ─── Milestone ─── */
.rm-milestone {
  position: absolute;
  width: 100%;
  transform: translateY(-50%);
  z-index: 2;
}

/* ─── Pin ─── */
.rm-pin-wrap {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 5;
}
.rm-pin {
  position: relative;
  width: 48px;
  height: 62px;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.15));
  /* Start above, invisible — like held above the map */
  opacity: 0;
  transform: translateY(-40px) scale(0.6);
}
/* Pin drops in with bounce */
.rm-milestone.visible .rm-pin {
  animation: pinDrop 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards,
             pinFloat 3s ease-in-out 1.5s infinite;
}
@keyframes pinDrop {
  0%   { opacity: 0; transform: translateY(-40px) scale(0.6); }
  50%  { opacity: 1; transform: translateY(4px) scale(1.05); }
  70%  { transform: translateY(-2px) scale(0.98); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}
@keyframes pinFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-4px) scale(1); }
}

/* Ripple pulse on pin land */
.rm-pin::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 50%;
  width: 20px;
  height: 8px;
  border-radius: 50%;
  background: currentColor;
  opacity: 0;
  transform: translateX(-50%) scale(0);
}
.rm-milestone.visible .rm-pin::after {
  animation: pinRipple 0.8s ease-out 0.4s forwards;
}
@keyframes pinRipple {
  0%   { opacity: 0.5; transform: translateX(-50%) scale(0.5); }
  100% { opacity: 0; transform: translateX(-50%) scale(3); }
}

.rm-pin-shape { width: 100%; height: 100%; }
.rm-pin-orange { color: var(--color-accent-orange); }
.rm-pin-purple { color: var(--color-accent-purple); }
.rm-pin-icon {
  position: absolute;
  top: 10px; left: 50%;
  transform: translateX(-50%);
  width: 20px; height: 20px;
  color: #1a1a2e;
}

/* ─── Card ─── */
.rm-card {
  position: absolute;
  top: 50%;
  width: 340px;
  padding: 28px 32px;
  border: 1px solid rgba(0,0,0,0.08) !important;
  background: #fff !important;
  backdrop-filter: none !important;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  /* Hidden before reveal */
  opacity: 0;
  transform: translateY(-50%);
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}
/* Right-side cards slide from right */
.rm-right .rm-card {
  left: calc(70% + 48px);
}
.rm-milestone.visible.rm-right .rm-card {
  animation: cardSlideRight 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
}
/* Left-side cards slide from left */
.rm-left .rm-card {
  right: calc(70% + 48px);
}
.rm-milestone.visible.rm-left .rm-card {
  animation: cardSlideLeft 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
}

@keyframes cardSlideRight {
  0%   { opacity: 0; transform: translateY(-50%) translateX(50px); }
  100% { opacity: 1; transform: translateY(-50%) translateX(0); }
}
@keyframes cardSlideLeft {
  0%   { opacity: 0; transform: translateY(-50%) translateX(-50px); }
  100% { opacity: 1; transform: translateY(-50%) translateX(0); }
}

.rm-card-accent {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  opacity: 0;
  transition: opacity 0.5s ease;
}
.rm-milestone:nth-child(odd) .rm-card-accent {
  background: linear-gradient(90deg, #E85A20, #E02050);
}
.rm-milestone:nth-child(even) .rm-card-accent {
  background: linear-gradient(90deg, #635BFF, #00D4FF);
}
.rm-milestone.visible .rm-card-accent { opacity: 1; }

.rm-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.rm-card-step {
  font-size: 0.68rem; font-weight: 600;
  letter-spacing: 2px; color: #999;
 
}
.rm-card-year {
  font-size: 1.5rem; font-weight: 900; line-height: 1;
}
.rm-card-title {
  font-size: 1.15rem; font-weight: 700;
  color: #1a1a2e; margin-bottom: 10px;
}
.rm-card-desc {
  font-size: 0.88rem; line-height: 1.7;
  color: #666; margin-bottom: 16px;
}

/* Card decoration */
.rm-card-deco { display: flex; align-items: center; gap: 10px; }
.rm-deco-line { flex: 1; height: 1px; background: linear-gradient(90deg, rgba(232, 90, 32,0.3), transparent); }
.rm-deco-line:last-child { background: linear-gradient(90deg, transparent, rgba(232, 90, 32,0.3)); }
.rm-deco-diamond { width: 6px; height: 6px; background: var(--color-accent-orange); transform: rotate(45deg); opacity: 0.5; flex-shrink: 0; }
.rm-milestone:nth-child(even) .rm-deco-line { background: linear-gradient(90deg, rgba(99,91,255,0.3), transparent); }
.rm-milestone:nth-child(even) .rm-deco-line:last-child { background: linear-gradient(90deg, transparent, rgba(99,91,255,0.3)); }
.rm-milestone:nth-child(even) .rm-deco-diamond { background: var(--color-accent-purple); }

/* Hover */
.rm-milestone.visible .rm-card:hover {
  border-color: rgba(232, 90, 32,0.25) !important;
  box-shadow: 0 0 30px rgba(232, 90, 32,0.1), 0 12px 40px rgba(0,0,0,0.08) !important;
  transform: translateY(calc(-50% - 4px));
}
.rm-milestone:nth-child(even).visible .rm-card:hover {
  border-color: rgba(99,91,255,0.25) !important;
  box-shadow: 0 0 30px rgba(99,91,255,0.1), 0 12px 40px rgba(0,0,0,0.08) !important;
}

/* ─── CTA ─── */
.history-cta { padding: 80px 0; }
.history-cta .cta-card {
  text-align: center; padding: 60px 40px;
  background: linear-gradient(135deg, rgba(232, 90, 32,0.06), rgba(99,91,255,0.04));
  border: 1px solid rgba(232, 90, 32,0.15); border-radius: var(--radius-lg);
}
.history-cta .cta-card h2 { font-size: 1.8rem; margin-bottom: 16px; color: var(--color-text-dark); }
.history-cta .cta-card p { max-width: 500px; margin: 0 auto 32px; color: var(--color-text-dark-secondary); }

/* ─── Responsive ─── */
@media (max-width: 1024px) {
  .rm-card { width: 280px; padding: 22px 24px; }
  .rm-right .rm-card { left: calc(70% + 36px); }
  .rm-left .rm-card { right: calc(70% + 36px); }
}

@media (max-width: 768px) {
  .history-hero { min-height: 60vh; padding: 120px 0 60px; }
  .history-hero h1 { font-size: clamp(1.8rem, 6vw, 2.6rem); }
  .history-hero-sub { font-size: 0.95rem; margin-bottom: 32px; }
  .history-stats { flex-direction: column; gap: 20px; padding: 28px 32px; }
  .history-stat-divider { width: 60px; height: 1px; }
  .history-stat-num { font-size: 2.2rem; }
  .hero-scroll-hint { display: none; }

  .roadmap-section { padding: 60px 0 80px; }
  .vtl-header { margin-bottom: 40px; }

  /* Switch to vertical list on mobile */
  .roadmap-container {
    position: relative;
    padding-bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .roadmap-svg { display: none; }

  .rm-milestone {
    position: relative !important;
    top: auto !important;
    width: 100% !important;
    transform: none !important;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding-left: 60px;
  }
  .rm-milestone.rm-right,
  .rm-milestone.rm-left {
    transform: translateY(20px) !important;
