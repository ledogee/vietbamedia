---
import Layout from '../layouts/Layout.astro';
import vi from '../i18n/vi.json';
const t = vi;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const milestoneIcons: Record<string, string> = {
  '1999': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/></svg>`,
  '2001': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  '2007': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>`,
  '2009': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20V10M6 20V4M18 20v-6"/></svg>`,
  '2012': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
  '2014': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>`,
  '2015': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M12 17v4M7 21h10"/><path d="M9 10l2 2 4-4"/></svg>`,
  '2022': `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
};
---

<Layout lang="vi">
  <!-- Immersive Hero -->
  <section class="history-hero">
    <div class="history-hero-bg" aria-hidden="true">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
    </div>
    <div class="container history-hero-content">
      <p class="section-tag fade-in">{t.pageHero.history.tag}</p>
      <h1 class="section-title fade-in">{t.pageHero.history.title}</h1>
      <p class="history-hero-sub fade-in">{t.pageHero.history.subtitle}</p>
      <div class="history-stats fade-in">
        <div class="history-stat">
          <span class="history-stat-num" data-target="27">0</span>
          <span class="history-stat-label">Năm Kinh Nghiệm</span>
        </div>
        <div class="history-stat-divider"></div>
        <div class="history-stat">
          <span class="history-stat-num" data-target="8">0</span>
          <span class="history-stat-label">Cột Mốc Quan Trọng</span>
        </div>
        <div class="history-stat-divider"></div>
        <div class="history-stat">
          <span class="history-stat-num" data-target="3">0</span>
          <span class="history-stat-label">Văn Phòng Toàn Quốc</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll-hint fade-in" aria-hidden="true">
      <span>Khám phá hành trình</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Vertical Timeline -->
  <section class="section section-dark vtl-section" style="background:var(--color-bg-dark)">
    <div class="container">
      <div class="vtl-header fade-in">
        <p class="section-tag">{t.timeline.sectionTag}</p>
        <h2 class="section-title">{t.timeline.title}</h2>
      </div>

      <div class="vtl-timeline">
        <div class="vtl-line" aria-hidden="true">
          <div class="vtl-line-progress" id="vtlProgress"></div>
        </div>

        {t.timeline.items.map((item, i) => (
          <div class={`vtl-item ${i % 2 === 0 ? 'vtl-left' : 'vtl-right'}`} data-index={i}>
            <div class="vtl-connector">
              <div class={`vtl-dot ${i === 0 ? 'active' : ''}`}>
                <div class="vtl-dot-icon" set:html={milestoneIcons[item.year] || milestoneIcons['1999']} />
                <div class="vtl-dot-ring"></div>
              </div>
              <span class="vtl-year-badge">{item.year}</span>
            </div>
            <div class="vtl-card glass-card">
              <div class="vtl-card-accent" aria-hidden="true"></div>
              <div class="vtl-card-header">
                <span class="vtl-card-step">{`${String(i + 1).padStart(2, '0')} / ${String(t.timeline.items.length).padStart(2, '0')}`}</span>
                <span class="vtl-card-year gradient-text">{item.year}</span>
              </div>
              <h3 class="vtl-card-title">{item.title}</h3>
              <p class="vtl-card-desc">{item.desc}</p>
              <div class="vtl-card-deco" aria-hidden="true">
                <span class="vtl-deco-line"></span>
                <span class="vtl-deco-diamond"></span>
                <span class="vtl-deco-line"></span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-light history-cta">
    <div class="container">
      <div class="cta-card fade-in">
        <h2>Sẵn sàng hợp tác?</h2>
        <p>Hãy kết nối với chúng tôi để cùng xây dựng chiến dịch truyền thông hiệu quả.</p>
        <a href={`${base}/contact`} class="btn-glow">Liên Hệ Ngay</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Counter animation
  const counters = document.querySelectorAll('.history-stat-num');
  const cObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        let current = 0;
        const step = Math.max(1, Math.ceil(target / 40));
        const timer = setInterval(() => {
          current += step;
          if (current >= target) { current = target; clearInterval(timer); }
          el.textContent = String(current);
        }, 30);
        cObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });
  counters.forEach((c) => cObserver.observe(c));

  // Scroll-reveal timeline items
  const items = document.querySelectorAll('.vtl-item');
  const progressBar = document.getElementById('vtlProgress');
  const timeline = document.querySelector('.vtl-timeline') as HTMLElement;

  const itemObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        (entry.target.querySelector('.vtl-dot') as HTMLElement)?.classList.add('active');
      }
    });
  }, { threshold: 0.3, rootMargin: '0px 0px -80px 0px' });
  items.forEach((item) => itemObserver.observe(item));

  // Progress line on scroll
  function updateProgress() {
    if (!timeline || !progressBar) return;
    const rect = timeline.getBoundingClientRect();
    const viewH = window.innerHeight;
    const start = rect.top + window.scrollY;
    const end = start + rect.height;
    const scroll = window.scrollY + viewH * 0.5;
    const pct = Math.min(1, Math.max(0, (scroll - start) / (end - start)));
    progressBar.style.height = `${pct * 100}%`;
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>

<style>
/* ─── History Hero ─── */
.history-hero {
  position: relative;
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 140px 0 80px;
  background: var(--color-bg-dark);
}
.history-hero-bg {
  position: absolute; inset: 0;
  pointer-events: none;
}
.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.4;
  animation: orbFloat 10s ease-in-out infinite alternate;
}
.hero-orb-1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(255,107,53,0.5), transparent 70%);
  top: -15%; right: -10%;
}
.hero-orb-2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(99,91,255,0.4), transparent 70%);
  bottom: -10%; left: -5%;
  animation-delay: -4s;
}
.hero-orb-3 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(0,212,255,0.35), transparent 70%);
  top: 40%; left: 45%;
  animation-delay: -7s;
}
@keyframes orbFloat {
  0% { transform: translate(0, 0) scale(1); }
  100% { transform: translate(25px, -20px) scale(1.12); }
}

.history-hero-content {
  position: relative; z-index: 2;
  text-align: center;
}
.history-hero h1 {
  color: var(--color-text-primary);
  font-size: clamp(2.2rem, 5vw, 3.5rem);
}
.history-hero-sub {
  font-size: 1.1rem;
  max-width: 560px;
  margin: 0 auto 48px;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* Stats Row */
.history-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40px;
  padding: 32px 48px;
  background: rgba(10, 37, 64, 0.6);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-lg);
  max-width: 680px;
  margin: 0 auto;
}
.history-stat {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
}
.history-stat-num {
  font-size: 2.8rem;
  font-weight: 900;
  background: var(--color-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}
.history-stat-label {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--color-text-muted);
}
.history-stat-divider {
  width: 1px; height: 48px;
  background: rgba(255,255,255,0.1);
}

/* Scroll Hint */
.hero-scroll-hint {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column;
  align-items: center; gap: 8px;
  color: var(--color-text-muted);
  font-size: 0.72rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  animation: scrollBounce 2s ease-in-out infinite;
}
@keyframes scrollBounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(6px); }
}

/* ─── Vertical Timeline ─── */
.vtl-section { padding: 100px 0 120px; overflow: hidden; }

.vtl-header {
  text-align: center;
  margin-bottom: 80px;
}

.vtl-timeline {
  position: relative;
  max-width: 1000px;
  margin: 0 auto;
}

/* Center line */
.vtl-line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 3px;
  background: rgba(255,255,255,0.06);
  transform: translateX(-50%);
  border-radius: 3px;
  z-index: 1;
}
.vtl-line-progress {
  width: 100%;
  height: 0%;
  background: var(--color-gradient);
  border-radius: 3px;
  box-shadow: 0 0 14px var(--color-glow-orange), 0 0 6px var(--color-glow-purple);
  transition: height 0.1s linear;
}

/* Timeline item */
.vtl-item {
  position: relative;
  display: flex;
  align-items: flex-start;
  margin-bottom: 60px;
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.7s ease, transform 0.7s ease;
  z-index: 2;
}
.vtl-item.visible {
  opacity: 1;
  transform: translateY(0);
}
.vtl-item:last-child { margin-bottom: 0; }

/* Left/right positioning */
.vtl-left { justify-content: flex-start; padding-right: calc(50% + 40px); }
.vtl-right { justify-content: flex-end; padding-left: calc(50% + 40px); }

.vtl-left .vtl-card { text-align: right; }
.vtl-right .vtl-card { text-align: left; }

/* Connector (dot + year) */
.vtl-connector {
  position: absolute;
  left: 50%;
  top: 20px;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  z-index: 5;
}

/* Dot */
.vtl-dot {
  width: 48px; height: 48px;
  border-radius: 50%;
  background: #0c2036;
  border: 2px solid rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
.vtl-dot-icon {
  width: 22px; height: 22px;
  color: var(--color-text-muted);
  transition: color 0.5s ease;
}
.vtl-dot-ring {
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  border: 2px solid transparent;
  transition: all 0.5s ease;
}
.vtl-dot.active {
  border-color: var(--color-accent-orange);
  box-shadow: 0 0 24px var(--color-glow-orange);
  background: linear-gradient(135deg, #2a1a10, #151028);
}
.vtl-dot.active .vtl-dot-icon { color: var(--color-accent-orange); }
.vtl-dot.active .vtl-dot-ring {
  border-color: rgba(255,107,53,0.25);
  animation: dotPulse 2.5s ease-in-out infinite;
}
.vtl-item:nth-child(even) .vtl-dot.active {
  border-color: var(--color-accent-purple);
  box-shadow: 0 0 24px var(--color-glow-purple);
  background: linear-gradient(135deg, #151028, #0a1e2e);
}
.vtl-item:nth-child(even) .vtl-dot.active .vtl-dot-icon { color: var(--color-accent-purple); }
.vtl-item:nth-child(even) .vtl-dot.active .vtl-dot-ring { border-color: rgba(99,91,255,0.25); }

@keyframes dotPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.5); opacity: 0; }
}

/* Year badge */
.vtl-year-badge {
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 1.5px;
  padding: 3px 12px;
  border-radius: 20px;
  background: #1a1209;
  color: var(--color-accent-orange);
  border: 1px solid rgba(255,107,53,0.15);
  white-space: nowrap;
}
.vtl-item:nth-child(even) .vtl-year-badge {
  background: #0e0f1e;
  color: var(--color-accent-cyan);
  border-color: rgba(99,91,255,0.15);
}

/* Card */
.vtl-card {
  position: relative;
  padding: 32px 36px;
  overflow: hidden;
  width: 100%;
  border: 1px solid rgba(255,255,255,0.08) !important;
  background: rgba(12, 32, 54, 0.6) !important;
  backdrop-filter: blur(24px) !important;
}
.vtl-card-accent {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #FF6B35, #FF3864);
  opacity: 0;
  transition: opacity 0.5s ease;
}
.vtl-item:nth-child(even) .vtl-card-accent {
  background: linear-gradient(90deg, #635BFF, #00D4FF);
}
.vtl-item.visible .vtl-card-accent { opacity: 1; }

.vtl-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}
.vtl-left .vtl-card-header { flex-direction: row-reverse; }

.vtl-card-step {
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 2px;
  color: var(--color-text-muted);
  text-transform: uppercase;
}
.vtl-card-year {
  font-size: 1.6rem;
  font-weight: 900;
  line-height: 1;
}

.vtl-card-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 12px;
}
.vtl-card-desc {
  font-size: 0.92rem;
  line-height: 1.8;
  color: var(--color-text-secondary);
  margin-bottom: 20px;
}

/* Card bottom decoration */
.vtl-card-deco {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 4px;
}
.vtl-deco-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, rgba(255,107,53,0.3), transparent);
}
.vtl-deco-line:last-child {
  background: linear-gradient(90deg, transparent, rgba(255,107,53,0.3));
}
.vtl-deco-diamond {
  width: 6px;
  height: 6px;
  background: var(--color-accent-orange);
  transform: rotate(45deg);
  opacity: 0.5;
  flex-shrink: 0;
}
.vtl-item:nth-child(even) .vtl-deco-line {
  background: linear-gradient(90deg, rgba(99,91,255,0.3), transparent);
}
.vtl-item:nth-child(even) .vtl-deco-line:last-child {
  background: linear-gradient(90deg, transparent, rgba(99,91,255,0.3));
}
.vtl-item:nth-child(even) .vtl-deco-diamond {
  background: var(--color-accent-purple);
}

/* Hover */
.vtl-card:hover {
  border-color: rgba(255,107,53,0.2) !important;
  box-shadow: 0 0 40px var(--color-glow-orange), 0 12px 40px rgba(0,0,0,0.3) !important;
  transform: translateY(-4px);
}
.vtl-item:nth-child(even) .vtl-card:hover {
  border-color: rgba(99,91,255,0.2) !important;
  box-shadow: 0 0 40px var(--color-glow-purple), 0 12px 40px rgba(0,0,0,0.3) !important;
}

/* Stagger reveal */
.vtl-item:nth-child(1) { transition-delay: 0s; }
.vtl-item:nth-child(2) { transition-delay: 0.08s; }
.vtl-item:nth-child(3) { transition-delay: 0.05s; }
.vtl-item:nth-child(4) { transition-delay: 0.08s; }

/* Left items slide from left */
.vtl-left { transform: translateY(40px) translateX(-30px); }
.vtl-left.visible { transform: translateY(0) translateX(0); }
.vtl-right { transform: translateY(40px) translateX(30px); }
.vtl-right.visible { transform: translateY(0) translateX(0); }

/* ─── CTA ─── */
.history-cta { padding: 80px 0; }
.history-cta .cta-card {
  text-align: center;
  padding: 60px 40px;
  background: linear-gradient(135deg, rgba(255,107,53,0.06), rgba(99,91,255,0.04));
  border: 1px solid rgba(255,107,53,0.15);
  border-radius: var(--radius-lg);
}
.history-cta .cta-card h2 {
  font-size: 1.8rem;
  margin-bottom: 16px;
  color: var(--color-text-dark);
}
.history-cta .cta-card p {
  max-width: 500px;
  margin: 0 auto 32px;
  color: var(--color-text-dark-secondary);
}

/* ─── Responsive ─── */
@media (max-width: 768px) {
  .history-hero { min-height: 60vh; padding: 120px 0 60px; }
  .history-hero h1 { font-size: clamp(1.8rem, 6vw, 2.6rem); }
  .history-hero-sub { font-size: 0.95rem; margin-bottom: 32px; }
  .history-stats { flex-direction: column; gap: 20px; padding: 28px 32px; }
  .history-stat-divider { width: 60px; height: 1px; }
  .history-stat-num { font-size: 2.2rem; }
  .hero-scroll-hint { display: none; }

  .vtl-section { padding: 60px 0 80px; }
  .vtl-header { margin-bottom: 48px; }

  /* Single column layout on mobile */
  .vtl-line { left: 24px; }
  .vtl-connector { left: 24px; }
  .vtl-left, .vtl-right {
    padding-left: 72px;
    padding-right: 0;
    justify-content: flex-start;
  }
  .vtl-left .vtl-card, .vtl-right .vtl-card { text-align: left; }
  .vtl-left .vtl-card-header { flex-direction: row; }
  .vtl-left .vtl-card-tag-row { justify-content: flex-start; }
  .vtl-left, .vtl-right { transform: translateY(40px) translateX(0); }
  .vtl-left.visible, .vtl-right.visible { transform: translateY(0) translateX(0); }

  .vtl-dot { width: 40px; height: 40px; }
  .vtl-dot-icon { width: 18px; height: 18px; }
  .vtl-card { padding: 24px 20px; }
  .vtl-card-year { font-size: 1.3rem; }
  .vtl-card-title { font-size: 1.1rem; }
  .vtl-card-desc { font-size: 0.85rem; }
  .vtl-item { margin-bottom: 40px; }

  .history-cta { padding: 48px 0; }
  .history-cta .cta-card { padding: 36px 24px; }
  .history-cta .cta-card h2 { font-size: 1.4rem; }
}

@media (max-width: 480px) {
  .history-hero { padding: 100px 0 48px; min-height: 55vh; }
  .history-stats { padding: 20px 24px; gap: 16px; }
  .history-stat-num { font-size: 1.8rem; }
  .history-stat-label { font-size: 0.62rem; }

  .vtl-line { left: 18px; }
  .vtl-connector { left: 18px; }
  .vtl-left, .vtl-right { padding-left: 56px; }
  .vtl-dot { width: 34px; height: 34px; }
  .vtl-dot-icon { width: 15px; height: 15px; }
  .vtl-dot-ring { inset: -6px; }
  .vtl-card { padding: 20px 16px; }
  .vtl-card-year { font-size: 1.1rem; }
  .vtl-card-title { font-size: 1rem; }
  .vtl-card-desc { font-size: 0.82rem; line-height: 1.7; }
  .vtl-item { margin-bottom: 32px; }
}
</style>
